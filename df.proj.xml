<data-definition>
    <enum-type type-name='projectile_type'> bay12: Projectile
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Item' original-name='ITEM'/>
        <enum-item name='Unit' original-name='UNIT'/>
        <enum-item name='Magic' original-name='MAGIC'/>
    </enum-type>

    <bitfield-type type-name='projectile_flags' original-name='proj_flag' base-type='uint32_t'> bay12: PROJFLAG_*
        <flag-bit name='no_impact_destroy' original-name='LANDS'/>
        <flag-bit name='has_hit_ground' original-name='DELETE'/>
        <flag-bit name='bouncing' original-name='BOUNCES'/>
        <flag-bit name='high_flying' original-name='AVOIDS'/>
        <flag-bit name='piercing' original-name='PUSHTHROUGH'/>
        <flag-bit name='to_be_deleted' original-name='MUST_REMOVE'/>
        <flag-bit name='hits_friends' original-name='HITS_FRIENDS'/>
        <flag-bit name='trap_origin' original-name='TRAP_ORIGIN'/>

        <flag-bit name='parabolic' original-name='USE_PHYSICS'/>
        <flag-bit name='no_adv_pause' original-name='NO_ADV_PAUSE'/>
        <flag-bit name='vehicle_origin' original-name='VEHICLE_ORIGIN'/>
        <flag-bit name='no_collide' original-name='AVOIDS_ITEM'/>
        <flag-bit name='safe_landing' original-name='CONTROLLED_JUMP'/>
        <flag-bit name='struck' original-name='STRUCK'/>
        <flag-bit name='auto_hit' original-name='AUTO_HIT'/>
        <flag-bit name='item_link_deleted' original-name='ITEM_LINK_DELETED'/>

        <flag-bit name='small_aim_minus' original-name='SMALL_AIM_MINUS'/>
        <flag-bit name='created_in_tantrum' original-name='CREATED_IN_TANTRUM'/>
    </bitfield-type>

    <df-linked-list-type type-name='proj_list_link' item-type='projectile'/>
    <class-type type-name='projectile' original-name='projst' df-list-link-type='proj_list_link' df-list-link-field='link' key-field='id'>
        <pointer name='link' original-name='my_link' type-name='proj_list_link'/>

        <int32_t name='id' original-name='global_id'/>
        <pointer name='firer' original-name='archer' type-name='unit'/>

        <compound name='origin_pos' original-name='s' type-name='coord'/>
        <compound name='target_pos' original-name='e' type-name='coord'/>
        <compound name='cur_pos' original-name='pos' type-name='coord'/>
        <compound name='prev_pos' original-name='o' type-name='coord'/>

        <int32_t name='distance_flown' original-name='step'/>
        <int32_t name='fall_threshold' original-name='maxstep'/>
        <int32_t name='min_hit_distance' original-name='effstep'/>
        <int32_t name='min_ground_distance' original-name='effstep_ground'/>

        <bitfield name='flags' original-name='flag' type-name='projectile_flags'/>

        <int16_t name='fall_counter' original-name='flydelay' comment='counts down from delay to 0, then it moves'/>
        <int16_t name='fall_delay' original-name='flydelaymax'/>

        <int32_t name='hit_rating' original-name='hitroll'/>
        <int32_t name='total_z_dist'/>
        <int32_t name='velocity'/>
        <int32_t name='bow_id' original-name='shooter_item_id' ref-target='item'/>

        <int32_t name="last_knock_item" original-name='last_knock_item_id' ref-target='item'/>
        <int32_t name="last_knock_unit" original-name='last_knock_unit_id' ref-target='unit'/>
        <int32_t name="spec_target_unit" original-name='specified_target_unid' ref-target='unit' since='v0.40.01' comment='uninitialized+saved'/>
        <int16_t name='target_bp'/>
        <int32_t name='hit_chance_modifier'/>

        -- Parabolic projectile info:
        <int32_t name="pos_x" original-name='fine_x_adj'/>
        <int32_t name="pos_y" original-name='fine_y_adj'/>
        <int32_t name="pos_z" original-name='fine_z_adj'/>
        <int32_t name="speed_x" original-name='fine_x_vel'/>
        <int32_t name="speed_y" original-name='fine_y_vel'/>
        <int32_t name="speed_z" original-name='fine_z_vel'/>
        <int32_t name="accel_x" original-name='fine_x_gain_vel'/>
        <int32_t name="accel_y" original-name='fine_y_gain_vel'/>
        <int32_t name="accel_z" original-name='fine_z_gain_vel'/>

        <virtual-methods>
            <vmethod ret-type='projectile_type' name='getType' original-name='type'/>
            <vmethod ret-type='bool' name='checkImpact' original-name='landproj'>
                <bool name='goingoutofbounds'/>
            </vmethod>
            <vmethod ret-type='bool' name='checkMovement' original-name='advance'/>
            <vmethod name='read_file'>
                <pointer name='filecomp' type-name='file_compressorst'/>
                <enum name='loadversion' type-name='save_version'/>
            </vmethod>
            <vmethod name='write_file'> <pointer name='filecomp' type-name='file_compressorst'/> </vmethod>
            <vmethod name='print'><pointer type-name='map_viewport' name='rparam'/></vmethod>
            <vmethod name='print_to_viewport'><pointer type-name='map_viewport' name='rparam'/></vmethod>
            <vmethod ret-type='bool' name='isObjectLost' original-name='invalid_pointer'/>
            <vmethod is-destructor='true'/>
        </virtual-methods>
    </class-type>

    <class-type type-name='proj_itemst' inherits-from='projectile'>
        <pointer name='item' original-name='it' type-name='item'/>
    </class-type>

    <class-type type-name='proj_unitst' inherits-from='projectile'>
        <pointer name='unit' original-name='un' type-name='unit'/>
    </class-type>

    <enum-type type-name='proj_magic_type'> bay12: ProjMagicType
        <enum-item name='FIREBALL'/>
    </enum-type>

    <class-type type-name='proj_magicst' inherits-from='projectile'>
        <enum name='type' original-name='mtype' type-name='proj_magic_type' base-type='int16_t'/>
        <int16_t name='damage' original-name='power'/>
    </class-type>

    <struct-type type-name='proj_handlerst'>
        <df-linked-list name='all' original-name='global' type-name='proj_list_link'/>
    </struct-type>
</data-definition>

