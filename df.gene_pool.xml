<data-definition>
    <struct-type type-name='gene_pool_body_modifierst'>
        <int32_t name='id' original-name='local_id'/>
        <int32_t name="roll_min"/>
        <int32_t name="roll_max"/>
    </struct-type>

    <struct-type type-name='gene_pool_bp_modifierst'>
        <int32_t name='id' original-name='local_id'/>
        <int32_t name="roll_min"/>
        <int32_t name="roll_max"/>
    </struct-type>

    <struct-type type-name='gene_pool_color_modifierst'>
        <int32_t name="id" original-name='local_id'/>
        <int32_t name="roll" comment='from creature frequency value, -1 = all colors used according to creature frequencies'/>
    </struct-type>

    <struct-type type-name='gene_poolst'>
        <stl-vector pointer-type='gene_pool_body_modifierst' name="body_modifier"/>
        <stl-vector pointer-type='gene_pool_bp_modifierst' name="bp_modifier"/>
        <stl-vector pointer-type='gene_pool_color_modifierst' name="color_modifier"/>
    </struct-type>
</data-definition>

