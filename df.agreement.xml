<data-definition>
    <struct-type type-name='agreement_complaintst'>
        <enum type-name='history_event_reason' name='reason' original-name='type'/>
        <int32_t name='subject_id' ref-target='agreement_details'/>
        <int32_t name='year'/>
        <int32_t name='tick' original-name='season_count'/>
    </struct-type>

    <struct-type type-name='agreement_party' original-name='agreement_partyst' key-field='id'>
        <int32_t name='id' original-name='local_id'/>

        <stl-vector type-name='int32_t' name='histfig_ids' original-name='hfid' ref-target='historical_figure' comment='binary'/>
        <stl-vector type-name='int32_t' name='entity_ids' original-name='enid' ref-target='historical_entity' comment='binary'/>

        <stl-vector pointer-type='agreement_complaintst' name='complaint'/>
    </struct-type>

    <enum-type type-name='agreement_details_type' original-name='agreement_subject_type' base-type='int32_t'> bay12: AgreementSubjectType
        <enum-item name='JoinParty' original-name='JOIN_AS_COMPANION'/>
        <enum-item name='DemonicBinding' original-name='ATTACH_TO_WORLD'/>
        <enum-item name='Residency' original-name='BECOME_RESIDENT'/>
        <enum-item name='Citizenship' original-name='BECOME_CITIZEN'/>
        <enum-item name='Parley' original-name='ARRANGE_PARLEY'/>
        <enum-item name='PositionCorruption' original-name='POSITION_CORRUPTION' comment="Embezzlement and accepting bribes seen. For own gain and for 'sponsor'"/>
        <enum-item name='PlotStealArtifact' original-name='STEAL_ARTIFACT'/>
        <enum-item name='PromisePosition' original-name='PROMISE_OF_POSITION'/>
        <enum-item name='PlotAssassination' original-name='ASSASSINATE'/>
        <enum-item name='PlotAbduct' original-name='ABDUCT'/>
        <enum-item name='PlotSabotage' original-name='SABOTAGE'/>
        <enum-item name='PlotConviction' original-name='FOILED_CONSPIRACY'/>
        <enum-item name='Location' original-name='BUILD_LOCATION'/>
        <enum-item name='PlotInfiltrationCoup' original-name='INFILTRATE_SOCIETY'/>
        <enum-item name='PlotFrameTreason' original-name='FRAME_FOR_CRIME'/>
        <enum-item name='PlotInduceWar' original-name='START_WAR_WITH_ENTITY'/>
        <enum-item name='OfferService' original-name='OFFER_SERVICE'/>
        <enum-item name='RetrieveArtifact' original-name='RETRIEVE_ARTIFACT'/>
    </enum-type>

    <struct-type type-name='agreement_details_data_join_party' original-name='agreement_subject_join_as_companionst'>
        <enum base-type='int32_t' type-name='history_event_reason' name='reason'/>
        -- Here be unions!
        <int32_t name='member' original-name='joining_party_id' ref-target='agreement_party'/>
        <int32_t name='party' original-name='joined_party_id' ref-target='agreement_party'/>
        <int32_t name='site' original-name='stid' ref-target='world_site' comment='possibly a Year, if for entertainment'/>
        <int32_t name='entity' original-name='target_enid' ref-target='historical_entity' comment='possibly a Season, or an Identity'/>
        <int32_t name='figure' original-name='hfid' ref-target='historical_figure' comment='this is a value_type when reason == sphere_alignment'/>
        <int32_t name='end_year'/>
        <int32_t name='end_season_tick' original-name='end_season_count'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_residency' original-name='agreement_subject_become_residentst'>
        <enum base-type='int32_t' type-name='history_event_reason' name='reason'/>
        <int32_t name='applicant' original-name='joining_party_id' ref-target='agreement_party'/>
        <int32_t name='government' original-name='joined_party_id' ref-target='agreement_party'/>
        <int32_t name='site' original-name='stid' ref-target='world_site'/>
        <int32_t name='end_year'/>
        <int32_t name='end_season_tick' original-name='end_season_count'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_citizenship' original-name='agreement_subject_become_citizenst'>
        <int32_t name='applicant' original-name='joining_party_id' ref-target='agreement_party'/>
        <int32_t name='government' original-name='joined_party_id' ref-target='agreement_party'/>
        <int32_t name='site' original-name='stid' ref-target='world_site'/>
        <int32_t name='end_year'/>
        <int32_t name='end_season_tick' original-name='end_season_count'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_demonic_binding' original-name='agreement_subject_attach_to_worldst'>
        <enum base-type='int32_t' type-name='history_event_reason' name='reason'/>
        <int32_t name='demon' original-name='attached_party_id' ref-target='agreement_party'/>
        <int32_t name='summoner' original-name='attacher_party_id' ref-target='agreement_party'/>
        <int32_t name='site' original-name='stid' ref-target='world_site'/>
        <int32_t name='artifact' original-name='artifact_id' ref-target='artifact_record'/>
        <enum base-type='int32_t' type-name='sphere_type' name='sphere'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_parley' original-name='agreement_subject_arrange_parleyst'>
        <enum base-type='int32_t' type-name='history_event_reason' name='reason'/>
        <int32_t name='asker' original-name='asking_party_id' ref-target='agreement_party'/>
        <int32_t name='target' original-name='asked_party_id' ref-target='agreement_party'/>
        <int32_t name='site' original-name='stid' ref-target='world_site'/>
        <int32_t name='end_year'/>
        <int32_t name='end_season_tick' original-name='end_season_count'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_position_corruption' original-name='agreement_subject_position_corruptionst'>
        <enum type-name='unit_thought_type' name='corrupt_circumstance'/>
        <int32_t name='actor_index' original-name='corrupt_party_id' ref-target='agreement_party'/>
        <int32_t name='influencer_index' original-name='corruptor_party_id' ref-target='agreement_party'/>
        <int32_t name='intermediary_index' original-name='messenger_party_id' ref-target='agreement_party'/>
        <int32_t name='target_id' original-name='related_enid' ref-target='historical_entity'/>
        <int32_t name='position_id' original-name='related_eppid' comment="position index in the entity's Own entity_position vector"/>
    </struct-type>

    <struct-type type-name='agreement_details_data_plot_assassination' original-name='agreement_subject_assassinatest'>
        <int32_t name='actor_index' original-name='assassin_party_id' ref-target='agreement_party'/>
        <int32_t name='influencer_index' original-name='client_party_id' ref-target='agreement_party'/>
        <int32_t name='intermediary_index' original-name='messenger_party_id' ref-target='agreement_party'/>
        <int32_t name='target_id' original-name='target_hfid' ref-target='historical_figure'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_plot_abduct' original-name='agreement_subject_abductst'>
        <int32_t name='actor_index' original-name='snatcher_party_id' ref-target='agreement_party'/>
        <int32_t name='influencer_index' original-name='client_party_id' ref-target='agreement_party'/>
        <int32_t name='intermediary_index' original-name='messenger_party_id' ref-target='agreement_party'/>
        <int32_t name='target_id' original-name='target_hfid' ref-target='historical_figure'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_plot_conviction' original-name='agreement_subject_foiled_conspiracyst'>
        <stl-vector type-name='int32_t' name='criminal_indices' original-name='party_id' ref-target='agreement_party'/>
        <enum type-name='intrigue_corruption_action_type' name='corruption_action'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_plot_infiltration_coup' original-name='agreement_subject_infiltrate_societyst'>
        <int32_t name='actor_index' original-name='infiltrator_party_id' ref-target='agreement_party'/>
        <int32_t name='influencer_index' original-name='client_party_id' ref-target='agreement_party'/>
        <int32_t name='target' original-name='target_enid' ref-target='historical_entity'/>
        <uint32_t name='flags' original-name='infiltrate_flag'/> bay12: INTRIGUE_PLOT_INFILTRATE_SOCIETY_FLAG_* ?
    </struct-type>

    <struct-type type-name='agreement_details_data_plot_frame_treason' original-name='agreement_subject_frame_for_crimest'>
        <int32_t name='actor_index' original-name='framer_party_id' ref-target='agreement_party'/>
        <int32_t name='influencer_index' original-name='client_party_id' ref-target='agreement_party'/>
        <int32_t name='victim_id' original-name='target_hfid' ref-target='historical_figure'/>
        <int32_t name='fool_id' original-name='fooled_enforcer_hfid' ref-target='historical_figure'/>
        <enum type-name='crime_type' name='crime'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_plot_induce_war' original-name='agreement_subject_start_war_with_entityst'>
        <int32_t name='actor_index' original-name='active_party_id' ref-target='agreement_party'/>
        <int32_t name='influencer_index' original-name='client_party_id' ref-target='agreement_party'/>
        <int32_t name='attacker' original-name='starter_enid' ref-target='historical_entity'/>
        <int32_t name='defender' original-name='target_enid' ref-target='historical_entity'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_plot_sabotage' original-name='agreement_subject_sabotagest'>
        <int32_t name='plotter_index' original-name='saboteur_party_id' ref-target='agreement_party'/>
        <int32_t name='actor_index' original-name='client_party_id' ref-target='agreement_party'/>
        <int32_t name='intermediary_index' original-name='messenger_party_id' ref-target='agreement_party'/>
        <int32_t name='victim_id' original-name='target_hfid' ref-target='historical_figure'/>
        <int32_t name='victim_civ' original-name='target_enid' ref-target='historical_entity'/>
        <int32_t name='victim_site' original-name='target_stid' ref-target='world_site'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_plot_steal_artifact' original-name='agreement_subject_steal_artifactst'>
        <int32_t name='actor_index' original-name='thief_party_id' ref-target='agreement_party'/>
        <int32_t name='influencer_index' original-name='client_party_id' ref-target='agreement_party'/>
        <int32_t name='intermediary_index' original-name='messenger_party_id' ref-target='agreement_party'/>
        <int32_t name='artifact_id' ref-target='artifact_record'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_promise_position' original-name='agreement_subject_promise_of_positionst'>
        <int32_t name='beneficiary_index' original-name='beneficiary_party_id' ref-target='agreement_party'/>
        <int32_t name='actor_index' original-name='giver_party_id' ref-target='agreement_party'/>
        <int32_t name='promisee_index' original-name='asker_party_id' ref-target='agreement_party'/>
        <int32_t name='influencer_index' original-name='initiator_party_id' ref-target='agreement_party'/>
        <stl-vector type-name='int32_t' name='intermediary_indices' original-name='messenger_party_id' ref-target='agreement_party'/>
        <int32_t name='entity_id' original-name='related_enid' ref-target='historical_entity'/>
    </struct-type>

    <bitfield-type type-name='agreement_subject_build_location_flag' base-type='uint32_t'> bay12: AGREEMENT_SUBJECT_BUILD_LOCATION_FLAG_*
        <flag-bit name='warned_is_ready' original-name='WARNED_IS_READY'/>
    </bitfield-type>

    <struct-type type-name='agreement_details_data_location' original-name='agreement_subject_build_locationst'>
        <int32_t name='applicant' original-name='asker_party_id' ref-target='agreement_party'/>
        <int32_t name='government' original-name='builder_party_id' ref-target='agreement_party'/>
        <int32_t name='site' original-name='stid' ref-target='world_site'/>
        <enum base-type='int32_t' type-name='abstract_building_type' name='type' original-name='ab_type'/>
        <enum type-name='religious_practice_type' name='deity_type' original-name='religious_practice'/>
        <compound type-name='religious_practice_data' name='deity_data' original-name='religious_practice_id'/>
        <enum type-name='profession' name='profession' original-name='desired_unit_type'/>
        <int32_t name='tier' original-name='desired_level' comment='1 = temple or guildhall, 2 = temple complex or grand guildhall; matches location_tier in abstract_building_contents'/>
        <bitfield base-type='uint32_t' type-name='agreement_subject_build_location_flag' name='flags' original-name='flag'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_offer_service' original-name='agreement_subject_offer_servicest'>
        <int32_t name='requesting_party' original-name='requesting_party_id' ref-target='agreement_party'/>
        <int32_t name='serving_party' original-name='serving_party_id' ref-target='agreement_party'/>
        <int32_t name='served_entity' original-name='served_enid' ref-target='historical_entity'/>
    </struct-type>

    <struct-type type-name='agreement_details_data_retrieve_artifact' original-name='agreement_subject_retrieve_artifactst'>
        <int32_t name='retrieving_party' original-name='retrieving_party_id' ref-target='agreement_party'/>
        <int32_t name='requesting_party' original-name='requesting_party_id' ref-target='agreement_party'/>
        <int32_t name='artifact' original-name='artifact_id' ref-target='artifact_record'/>
        <int32_t name='artifact_site' original-name='artifact_site_id' ref-target='world_site'/>
        <int32_t name='receiving_entity' original-name='receiving_entity_id' ref-target='historical_entity'/>
    </struct-type>

    <struct-type type-name='agreement_details' original-name='agreement_subjectst' key-field='id'>
        <int32_t name='id' original-name='local_id'/>
        <int32_t name='year' original-name='agree_year'/>
        <int32_t name='year_tick' original-name='agree_season_count'/>

        <compound name='data' is-union='true'>
            <pointer type-name='agreement_details_data_join_party' name='JoinParty' original-name='join_as_companion'/>
            <pointer type-name='agreement_details_data_demonic_binding' name='DemonicBinding' original-name='attach_to_world'/>
            <pointer type-name='agreement_details_data_residency' name='Residency' original-name='become_resident'/>
            <pointer type-name='agreement_details_data_citizenship' name='Citizenship' original-name='become_citizen'/>
            <pointer type-name='agreement_details_data_parley' name='Parley' original-name='arrange_parley'/>
            <pointer type-name='agreement_details_data_position_corruption' name='PositionCorruption' original-name='position_corruption'/>
            <pointer type-name='agreement_details_data_plot_steal_artifact' name='PlotStealArtifact' original-name='steal_artifact'/>
            <pointer type-name='agreement_details_data_promise_position' name='PromisePosition' original-name='promise_of_position'/>
            <pointer type-name='agreement_details_data_plot_assassination' name='PlotAssassination' original-name='assassinate'/>
            <pointer type-name='agreement_details_data_plot_abduct' name='PlotAbduct' original-name='abduct'/>
            <pointer type-name='agreement_details_data_plot_sabotage' name='PlotSabotage' original-name='sabotage'/>
            <pointer type-name='agreement_details_data_plot_conviction' name='PlotConviction' original-name='foiled_conspiracy'/>
            <pointer type-name='agreement_details_data_location' name='Location' original-name='build_location'/>
            <pointer type-name='agreement_details_data_plot_infiltration_coup' name='PlotInfiltrationCoup' original-name='infiltrate_society'/>
            <pointer type-name='agreement_details_data_plot_frame_treason' name='PlotFrameTreason' original-name='frame_for_crime'/>
            <pointer type-name='agreement_details_data_plot_induce_war' name='PlotInduceWar' original-name='start_war_with_entity'/>
            <pointer type-name='agreement_details_data_offer_service' name='OfferService' original-name='offer_service'/>
            <pointer type-name='agreement_details_data_retrieve_artifact' name='RetrieveArtifact' original-name='retrieve_artifact'/>
        </compound>

        <enum base-type='int32_t' type-name='agreement_details_type' name='type' original-name='subject'/>
    </struct-type>

    <bitfield-type type-name='agreement_flag' base-type='uint32_t' since='v0.42.01'> bay12: AGREEMENT_FLAG_*
        <flag-bit name='petition_not_accepted' original-name='NOT_APPROVED' comment='this gets unset by accepting a petition'/>
        <flag-bit name='convicted_accepted' original-name='CONCLUDED' comment="concluded"/>
    </bitfield-type>

    <struct-type type-name='agreement' key-field='id' original-name='agreementst'
                 instance-vector='$global.world.agreements.all'>
        <int32_t name='id' original-name='global_id'/>

        <stl-vector pointer-type='agreement_party' name='parties' original-name='party'/>
        <int32_t name='next_party_id'/>
        <stl-vector pointer-type='agreement_details' name='details' original-name='subject'/>
        <int32_t name='next_details_id' original-name='next_subject_id'/>

        <int32_t name='smm_x' original-name='made_abs_smm_x'/>
        <int32_t name='smm_y' original-name='made_abs_smm_y'/>

        <bitfield base-type='uint32_t' type-name='agreement_flag' name='flags' original-name='flag' since='v0.42.01'/>
    </struct-type>

    <struct-type type-name='agreement_handlerst'>
        <stl-vector pointer-type='agreement' name='all' original-name='global'/>
        <stl-vector pointer-type='agreement' name='order_load' has-bad-pointers='true'/>
    </struct-type>
</data-definition>

