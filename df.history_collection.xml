    </class-type>

    <class-type type-name='history_event_collection_ceremonyst' inherits-from='history_event_collection'>
        <int32_t name='parent_collection' original-name='parent_hecid' ref-target='history_event_collection' comment="all seen were occasions"/>
        <int32_t name='civ' original-name='enid' ref-target='historical_entity'/>
        <int32_t name='occasion' original-name='occid' comment="0-14 seen"/>
        <int32_t name='schedule' original-name='schedule_index' comment="0-10 seen"/>
        <int32_t name='ordinal'/>
    </class-type>
</data-definition>

