        <stl-vector name='figures' original-name='figure' pointer-type='historical_figure'/>

        <compound name='event_collections'> not a compound
            <stl-vector name='all' original-name='event_collection' pointer-type='history_event_collection'/>
            <static-array name='other' count='18' index-enum='history_event_collection_type'> not an array
                <stl-vector pointer-type='history_event_collection'/>
