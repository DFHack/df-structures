<data-definition>
    <bitfield-type type-name='intrigue_corruption_result_flag' base-type='uint32_t'> bay12: INTRIGUE_CORRUPTION_RESULT_FLAG_*
        <flag-bit name='succeeded' original-name='SUCCESSFUL'/>
        <flag-bit name='misread_target' original-name='FAILED_JUDGMENT_TEST'/>
    </bitfield-type>

    <enum-type type-name='intrigue_corruption_result_rel_factor_type' base-type='int32_t'> bay12: IntrigueCorruptionResultRelFactorType
        <enum-item name='None' original-name='NONE' value='-1'/>
        <enum-item name='Trust' original-name='TRUST'/>
        <enum-item name='Loyalty' original-name='LOYALTY'/>
        <enum-item name='Love' original-name='LOVE'/>
        <enum-item name='Fear' original-name='FEAR'/>
        <enum-item name='Respect' original-name='RESPECT'/>
    </enum-type>

    <struct-type type-name='intrigue_corruption' original-name='intrigue_corruption_resultst'>
        <enum name='action' type-name='intrigue_corruption_action_type'/>

        <int32_t name='corruptor_id' original-name='corruptor_hfid' ref-target='historical_figure'/>
        <int32_t name='target_id' original-name='target_hfid' ref-target='historical_figure'/>
        <enum name='target_relationship' original-name='relationship_to_corruptor' type-name='vague_relationship_type' comment="set if and only if action = BringIntoNetwork"/>
        <int32_t name='target_relationship_entity_id' original-name='relationship_to_corruptor_enid' ref-target='historical_entity' comment="Only set when relation = CommonEntity. Common Religion/PerformanceTroupe/MerchantCompany/Guild seen."/>

        <int32_t name='lurer_id' original-name='lure_hfid' ref-target='historical_figure' comment="Can be set with action = CorruptInPlace, not otherwise"/>

        <enum name='manipulation_type' original-name='method' base-type='int32_t' type-name='intrigue_corruption_method_type'/>
        <int32_t name='method_perceived_modifier' comment="-16 to 315 seen"/>
        <int32_t name='method_modifier' comment="-141 to 351 seen"/>

        <enum name='manipulated_facet' original-name='facet' type-name='personality_facet_type'/>
        <int32_t name='facet_rating'/>
        <int32_t name='facet_roll' original-name='facet_modifier'/>

        <enum name='manipulated_value' original-name='value' type-name='value_type'/>
        <int32_t name='value_rating'/>
        <int32_t name='value_roll' original-name='value_modifier'/>

        <enum name='manipulated_emotion' original-name='relationship_factor' type-name='intrigue_corruption_result_rel_factor_type'/>
        <int32_t name='emotion_rating' original-name='relationship_rating' comment="-100 to 125 seen"/>
        <int32_t name='emotion_roll' original-name='relationship_modifier' comment="-10 to 12 seen"/>

        <bitfield name='flags' original-name='flag' type-name='intrigue_corruption_result_flag' base-type='uint32_t'/>

        <int32_t name='position_entity_id' original-name='position_enid' ref-target='historical_entity' comment="Used to pull rank"/>
        <int32_t name='position_assignment_id' original-name='position_eppid' ref-target='entity_position_assignment' aux-value='$$.position_entity_id'/>

        <int32_t name='offered_id' original-name='relevant_id' ref-target='historical_figure' comment='deity or revenge target'/>
        <enum name='offered_relationship' original-name='relevant_hf_wg_relationship' type-name='vague_relationship_type' base-type='int32_t'/>

        <int32_t name='corruptor_ally_roll' original-name='assistance_mod'/>
        <int32_t name='target_ally_roll' original-name='resistance_mod'/>
    </struct-type>

    <bitfield-type type-name='interrogation_result_flag' base-type='uint32_t'> bay12: INTERROGATION_RESULT_FLAG_*
        <flag-bit name='successful' original-name='SUCCESSFUL'/>
        <flag-bit name='failed_judgment_test' original-name='FAILED_JUDGMENT_TEST'/>
    </bitfield-type>

    <enum-type type-name='interrogation_result_rel_factor_type' base-type='int32_t'> bay12: InterrogationResultRelFactorType
        <enum-item name='None' original-name='NONE' value='-1'/>
        <enum-item name='Trust' original-name='TRUST'/>
        <enum-item name='Loyalty' original-name='LOYALTY'/>
        <enum-item name='Love' original-name='LOVE'/>
        <enum-item name='Fear' original-name='FEAR'/>
        <enum-item name='Respect' original-name='RESPECT'/>
    </enum-type>

    <struct-type type-name='interrogation_resultst'>
        <int32_t name='officer_hf' original-name='interrogator_hfid' ref-target='historical_figure' comment='appears identical to officer_hf'/>
        <int32_t name='subject_hf' original-name='target_hfid' ref-target='historical_figure' comment='appears identical to subject_hf'/>
        <enum name='relationship_to_corruptor' original-name='relationship_to_interrogator' type-name='vague_relationship_type'/>
        <int32_t name='relationship_civ' original-name='relationship_to_interrogator_enid' ref-target='historical_entity'/>

        <enum name='method' type-name='interrogation_method_type'/>
        <int32_t name='method_perceived_modifier' init-value='-1000000'/>
        <int32_t name='method_modifier' init-value='-1000000'/>

        <enum name='facet' type-name='personality_facet_type'/>
        <int16_t name='facet_rating'/>
        <int32_t name='facet_modifier'/>

        <enum name='value' type-name='value_type'/>
        <int32_t name='value_rating'/>
        <int32_t name='value_modifier'/>

        <enum name='relationship_factor' type-name='interrogation_result_rel_factor_type'/>
        <int32_t name='relationship_rating'/>
        <int32_t name='relationship_modifier'/>

        <bitfield name='flags' original-name='flag' base-type='uint32_t' type-name='interrogation_result_flag'/>

        <int32_t name='position_enid' ref-target='historical_entity'/>
        <int32_t name='position_eppid' ref-target='entity_position_assignment'/>

        <int32_t name='relevant_id'/>
        <int32_t name='relevant_hf_wg_relationship'/>
    </struct-type>

    <bitfield-type type-name='interrogation_report_flag' base-type='uint32_t'> bay12: INTERROGATION_REPORT_FLAG_*
        <flag-bit name='viewed' original-name='VIEWED'/>
        <flag-bit name='current_id_is_newly_revealed' original-name='CURRENT_ID_IS_NEWLY_REVEALED'/>
    </bitfield-type>

    <struct-type type-name='interrogation_report' original-name='interrogation_reportst'>
        <stl-string name='title'/>
        <int32_t name='officer_hf' original-name='interrogator_hfid' ref-target='historical_figure'/>
        <int32_t name='subject_hf' original-name='target_hfid' ref-target='historical_figure'/>
        <stl-string name='officer_name' original-name='interrogator_name'/>
        <bitfield name='flags' original-name='flag' base-type='uint32_t' type-name='interrogation_report_flag'/>
        <int32_t name='year'/>
        <int32_t name='tick' original-name='season_count'/>
        <compound name='intcr' type-name='interrogation_resultst'/>
        <stl-vector name='confessed_target_crime_id' type-name='int32_t' ref-target='crime' comment='binary'/>
        <int32_t name='subject_identity_id' original-name='identity_id_when_interrogated' ref-target='identity'/>
        <stl-vector name='confessed_identity_id' type-name='int32_t' ref-target='identity' comment='binary'/>
        <stl-vector name='revealed_agreement_id' type-name='int32_t' ref-target='agreement' comment='binary'/>
        <stl-vector name='revealed_event_id' type-name='int32_t' ref-target='history_event' comment='binary, seen hfs_formed_intrigue_relationship'/>
        <stl-vector name='details' original-name='report_str' pointer-type='stl-string'/>
    </struct-type>

    <struct-type type-name='relationship_event_supplement' original-name='history_relationship_eventst'>
        <int32_t name='event' original-name='global_id' comment="can be found in the relationship_events"/>
        <enum name='circumstance' type-name='unit_thought_type'/>
        <compound name='circumstance_id' type-name='circumstance_id'/>
        <enum name='reason' type-name='history_event_reason'/>
        <compound name='reason_id' type-name='history_event_reason_id'/>
    </struct-type>

    <struct-type type-name='relationship_event' original-name='history_relationship_event_blockst'>
        <static-array name='event' original-name='event_id' type-name='int32_t' count='1024' comment="not included in the main list"/>
        <static-array name='relationship' type-name='vague_relationship_type' count='1024'/>
        <static-array name='source_hf' original-name='hfid_1' type-name='int32_t' count='1024' ref-target='historical_figure'/>
        <static-array name='target_hf' original-name='hfid_2' type-name='int32_t' count='1024' ref-target='historical_figure'/>
        <static-array name='year' type-name='int32_t' count='1024'/>
        <int32_t name='next_element' original-name='number' comment="1024 for all vectors except the last one"/>
        <int32_t name='start_year' comment="first year of the events contained in the element"/>
    </struct-type>

    <struct-type type-name='intrigue' instance-vector='$global.world.history.intrigues' key-field='event_id' original-name='history_support_eventst'>
        <int32_t name='event_id' original-name='global_id' ref-target='history_event' comment="NOTE: can be culled. Seen: failed_intrigue_corruption, event_agreement_formed, hfs_formed_intrigue_relationship"/>
        <pointer name='corruption' original-name='intcr' type-name='intrigue_corruption' comment="Mutually exclusive with circumstance. Exactly one is present. Presumably 'bring into network' action doesn't provide membership"/>
        <compound name='reason'> not a compound
            <enum name='type' original-name='reason' type-name='history_event_reason' base-type='int32_t'/>
            <compound name='data' original-name='reason_id' type-name='history_event_reason_id'/>
        </compound>
        <compound name='circumstance'> not a compound
            <enum name='type' original-name='circumstance' type-name='unit_thought_type' base-type='int32_t'/>
            <compound name='data' original-name='circumstance_id' type-name='circumstance_id'/>
        </compound>
    </struct-type>

    <enum-type type-name='era_type' base-type='int16_t'> bay12: EraType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='ThreePowers' original-name='THREE_POWERS'/>
        <enum-item name='TwoPowers' original-name='TWO_POWERS'/>
        <enum-item name='OnePower' original-name='ONE_POWER'/>
        <enum-item name='Myth' original-name='MYTH'/>
        <enum-item name='Legends' original-name='LEGENDS'/>
        <enum-item name='Twilight' original-name='TWILIGHT'/>
        <enum-item name='FairyTales' original-name='FAIRY_TALES'/>
        <enum-item name='Race' original-name='RACE_DOMINANT'/>
        <enum-item name='Heroes' original-name='HEROES'/>
        <enum-item name='Golden' original-name='GOLDEN'/>
        <enum-item name='Death' original-name='DEATH'/>
        <enum-item name='Civilization' original-name='CIVILIZATION'/>
        <enum-item name='Emptiness' original-name='EMPTINESS'/>
    </enum-type>

    <struct-type type-name='era_infost'>
        <enum type-name='era_type' name='type' original-name='era'/>
        <int32_t name='histfig_1' original-name='era_index1' ref-target='historical_figure' comment='or race'/>
        <int32_t name='histfig_2' original-name='era_index2' ref-target='historical_figure' comment='or race'/>
        <int32_t name='ordinal' original-name='era_number'/>
        <stl-string name='name' original-name='translated_name'/>
        <int32_t name='percent' original-name='max_race_perc' comment='either percentage of single race or percentage of mundane'/>
    </struct-type>

    <struct-type type-name='era_determinerst'>
        <int32_t name='living_powers' original-name='living_power_num'/>
        <int32_t name='living_megabeasts' original-name='living_mega_num'/>
        <int32_t name='living_semimegabeasts' original-name='living_semi_num'/>
        <static-array name='power_hf' original-name='mega_hfid' count='3' type-name='int32_t' ref-target='historical_figure'/>
        <stl-vector name='civilized_races' original-name='race_count' type-name='int32_t' index-refers-to='(find-creature $)'/>
        <int32_t name='civilized_total' original-name='race_total'/>
        <int32_t name='civilized_mundane' original-name='mundane_total'/>
    </struct-type>

    <struct-type type-name='history_era' original-name='erast'>
        <int32_t name='year' original-name='start_year'/>
        <compound name='title' original-name='info' type-name='era_infost'/>
        <compound name='details' original-name='determiner' type-name='era_determinerst'/>
    </struct-type>

    <struct-type type-name='world_history' original-name='historyst'>
        dtor 8532fa0

        <stl-vector name='events' original-name='event' pointer-type='history_event'/>
        <stl-vector name='events_death' original-name='event_death_implier' pointer-type='history_event'/>

        <stl-vector name='relationship_events' original-name='relationship_event_block' pointer-type='relationship_event' since='v0.47.01'/>
