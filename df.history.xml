        <bitfield type-name='knowledge_scholar_flags_8' name='first_geography_flag'/>
        <bitfield type-name='knowledge_scholar_flags_9' name='first_medicine_flag'/>
        <bitfield type-name='knowledge_scholar_flags_10' name='first_medicine_flag2'/>
        <bitfield type-name='knowledge_scholar_flags_11' name='first_medicine_flag3'/>
        <bitfield type-name='knowledge_scholar_flags_12' name='first_engineering_flag'/>
        <bitfield type-name='knowledge_scholar_flags_13' name='first_engineering_flag2'/>

        <stl-vector name='intrigues' original-name='history_support_event' since='v0.47.01' pointer-type='intrigue'/>

