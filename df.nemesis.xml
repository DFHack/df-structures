<data-definition>
    -- Unused: nem_unit_specifierst

    <enum-type type-name='nemesis_flags' original-name='nemesis_flag_type'> bay12: NemesisFlagType
        <enum-item name='ACTIVE_ADVENTURER' original-name='YOU' comment='used when loading save. Swapping the player character via tactical mode disables this flag on the old player character and sets it for the new one.'/>
        <enum-item name='UNUSED_02'/>
        <enum-item name='ADVENTURER' comment='blue color and guided by forces unknown description in legends mode'/>
        <enum-item name='TEMP_FLAG_ASSOCIATE_PEOPLE_TO_REALIZATION'/>
        <enum-item name='BRAG_ON_KILL'/>
        <enum-item name='KILL_QUEST'/>
        <enum-item name='CHAT_WORTHY'/>
        <enum-item name='FLASHES' comment='Causes the unit tile to flash between dark and light.'/>

        <enum-item name='DO_NOT_CULL'/>
        <enum-item name='HERO' original-name='STATUS_HERO' comment='Set after assigning the Hero status during adventure mode character creation, produces the vanguard of destiny description in legends mode.'/>
        <enum-item name='CHOSEN' original-name='STATUS_CHOSEN' comment='Set after assigning the Demigod status during adventure mode character creation, produces the divine parentage description in legends mode.'/>
        <enum-item name='POTENTIAL_CIVILIZED_ACTOR'/>
        <enum-item name='CHECK_FOR_POSITION_CLAIM'/>
        <enum-item name='POTENTIAL_PLOTTER_ACTOR'/>
    </enum-type>

    <struct-type type-name='nemesis_record' key-field='id' instance-vector='$global.world.nemesis.all' original-name='nemesisst'>
        <int32_t name='id' original-name='global_id' comment='sequential index in the array'/>

        <int32_t name='unit_id' ref-target='unit'/>
        <int32_t name='save_file_id' original-name='unit_chunk_id' ref-target='unit_chunk' comment='unit-*.dat'/>
        <int16_t name='member_idx' original-name='unit_chunk_member' comment='index in the file'/>

        <pointer type-name='historical_figure' name='figure' original-name='hist_fig'/>

        <pointer type-name='unit' name='unit'/>

        <code-helper name='describe'>
            (describe-obj $.figure)
        </code-helper>

        <int32_t name='group_leader_id' original-name='master_nemid' ref-target='nemesis_record'/>
        <stl-vector type-name='int32_t' name='companions' original-name='subord_nemid' ref-target='nemesis_record'/>

        <int16_t name='activeplotindex' init-value='-1'/>

        <int32_t name='travel_link_nemid' ref-target='nemesis_record'/>
        <int32_t name='ideal_item_container_id' init-value='-1'/>

        <int32_t name='next_plot_year'/>
        <int32_t name='next_plot_season_count'/>

        <df-flagarray name='flags' original-name='flag' index-enum='nemesis_flags'/>

        <size_t name='pool_id'/>
    </struct-type>

    <struct-type type-name='nemesis_handlerst'>
        <stl-vector pointer-type='nemesis_record' name='all' original-name='global'/>

        <stl-vector pointer-type='nemesis_record' name='independent_actor'/>
        <stl-vector pointer-type='nemesis_record' name='civilized_actor'/>
        <stl-vector pointer-type='nemesis_record' name='plotter_actor'/>
        <stl-vector pointer-type='nemesis_record' name='new_plotter_actor'/>
        <static-array name='teacher_actor' index-enum='goal_type'><stl-vector pointer-type='nemesis_record'/></static-array>
        <stl-vector pointer-type='nemesis_record' name='artist_actor'/>
        <stl-vector pointer-type='nemesis_record' name='poet_actor'/>
        <stl-vector pointer-type='nemesis_record' name='bard_actor'/>
        <stl-vector pointer-type='nemesis_record' name='dancer_actor'/>
        <stl-vector pointer-type='nemesis_record' name='scholar_actor'/>
        <stl-vector pointer-type='nemesis_record' name='hero_actor'/>
        <stl-vector pointer-type='nemesis_record' name='underbelly_actor'/>
        <stl-vector pointer-type='nemesis_record' name='religious_actor'/>
        <stl-vector pointer-type='nemesis_record' name='merchant_actor'/>

        <stl-vector pointer-type='nemesis_record' name='order_load' has-bad-pointers='true'/>

        <bool name='do_not_remove_from_vector'/>
    </struct-type>
</data-definition>

