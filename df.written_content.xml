<data-definition>
    <struct-type type-name='written_content' original-name='written_contentst' instance-vector='$global.world.written_contents.all' key-field='id'>
        <int32_t name='id' original-name='global_id'/>

        <stl-string name='title' original-name='title_string'/>

        <int32_t name='page_start' original-name='original_page_start'/>
        <int32_t name='page_end' original-name='original_page_end'/>

        <stl-vector pointer-type='general_ref' name='refs' original-name='gen_ref' comment='interactions learned'/>
        <stl-vector type-name='writing_role_type' name='ref_aux' original-name='gen_ref_role'/>

        <int32_t name='chapter_number' original-name='original_chapter_number' init-value='-1'/>
        <int32_t name='section_number' original-name='original_section_number' init-value='-1'/>

        <enum type-name='written_content_type' name='type' original-name='form'/>
        <int32_t name='poetic_form' original-name='form_id' since='v0.42.01' ref-target='poetic_form' comment='or musical composition or dance'/>

        <stl-vector type-name='written_content_style' name='styles' original-name='style'/>
        <stl-vector type-name='writing_style_modifier_type' name='style_strength' original-name='style_modifier'/>

        <int32_t name='author' original-name='author_hfid' ref-target='historical_figure'/>
        <int32_t name='author_roll' init-value='-1' comment='skill roll for quality'/>
    </struct-type>

    <struct-type type-name='written_content_handlerst'>
        <stl-vector pointer-type='written_content' name='all' original-name='global'/>

        <stl-vector pointer-type='written_content' name='order_load' has-bad-pointers='true'/>
    </struct-type>
</data-definition>

