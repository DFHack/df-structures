<data-definition>
    <bitfield-type type-name='vehicle_ram_graphics_flag' base-type='int64_t'> bay12: VEHICLE_RAM_GRAPHICS_FLAG_*
        <flag-bit name='wood_color_index' original-name='WOOD_COLOR_INDEX' count='8'/>
        <flag-bit name='bands_color_index' original-name='BANDS_COLOR_INDEX' count='8'/>
        <flag-bit name='head_color_index' original-name='HEAD_COLOR_INDEX' count='8'/>
        <flag-bit name='banded' original-name='BANDED'/>
        <flag-bit name='direction' original-name='DIRECTION' count='3'/>
        <flag-bit name='head_type' original-name='HEAD_TYPE' count='5'/>
        <flag-bit name='segment_type' original-name='SEGMENT_TYPE' count='2' type-name='vehicle_ram_graphics_flag_segment_type'/>
    </bitfield-type>

    <enum-type type-name='vehicle_ram_graphics_flag_segment_type' base-type='int64_t'> bay12: VEHICLE_RAM_GRAPHICS_FLAG_SEGMENT_TYPE_*
        <enum-item name='FRONT'/>
        <enum-item name='MIDDLE'/>
        <enum-item comment='not assigned'/>
        <enum-item name='BACK'/>
    </enum-type>

    <struct-type type-name='vehicle_ram_graphics_infost'>
        <bitfield base-type='int64_t' type-name='vehicle_ram_graphics_flag' name='flags' original-name='local_id'/>
        <int32_t name='texpos'/>
    </struct-type>

    <bitfield-type type-name='vehicle_ram_info_flag' base-type='uint32_t'> bay12: VEHICLE_RAM_INFO_FLAG_*
        <flag-bit name='ABANDONED'/>
    </bitfield-type>

    <struct-type type-name='vehicle_ram_infost'>
        <enum type-name='ram_head_type' name='head_type'/>
        <int16_t name='woodmat'/>
        <int16_t name='bandmat'/>
        <int16_t name='headmat'/>
        <int32_t name='woodmatg'/>
        <int32_t name='bandmatg'/>
        <int32_t name='headmatg'/>
        <uint8_t name='direction'/>
        <int16_t name='midx'/>
        <int16_t name='midy'/>
        <int16_t name='z'/>

        <int32_t name='move_delay'/>

        <bitfield base-type='uint32_t' type-name='vehicle_ram_info_flag' name='flag'/>
        <int32_t name='invader_start_abandon_year'/>
        <int32_t name='invader_start_abandon_season_count'/>
        <int32_t name='invader_start_abandon_attempts'/>
    </struct-type>

    <enum-type type-name='vehicle_type' base-type='int32_t'> bay12: VehicleType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='ITEM'/>
        <enum-item name='BATTERING_RAM'/>
    </enum-type>

    <bitfield-type type-name='vehicle_flag' base-type='uint32_t'> bay12: VEHICLE_FLAG_*
        <flag-bit name='ON_TRACK'/>
    </bitfield-type>

    <struct-type type-name='vehicle' original-name='vehiclest'
                 instance-vector='$global.world.vehicles.all' key-field='id'>
        <enum type-name='vehicle_type' name='type'/>
        <int32_t name='id' original-name='global_id'/>
        <int32_t name='item_id' ref-target='item'/>

        -- Position within tile
        <int32_t name='offset_x' original-name='fine_x_adj' comment='-50000..50000'/>
        <int32_t name='offset_y' original-name='fine_y_adj'/>
        <int32_t name='offset_z' original-name='fine_z_adj'/>

        <int32_t name='speed_x' original-name='fine_x_vel'/>
        <int32_t name='speed_y' original-name='fine_y_vel'/>
        <int32_t name='speed_z' original-name='fine_z_vel'/>

        <int32_t name='fine_x_gain_vel'/>
        <int32_t name='fine_y_gain_vel'/>
        <int32_t name='fine_z_gain_vel'/>
        <bitfield base-type='uint32_t' type-name='vehicle_flag' name='flag'/>

        <int32_t name='route_id' original-name='hauling_route_id' ref-target='hauling_route'/>

        <compound type-name='coord' name='last_dump'/>

        <int32_t name='time_stopped' original-name='zero_vel_count' comment='frames, up to 1000'/>

        <int32_t name='invasion_id' ref-target='invasion_info'/>
        <int32_t name='invasion_section_index'/>

        <pointer type-name='vehicle_ram_infost' name='ram_info'/>
    </struct-type>

    <struct-type type-name='vehicle_handlerst'>
        <stl-vector pointer-type='vehicle' name='all' original-name='global'/>

        <stl-vector pointer-type='vehicle' name='active' original-name='play'/>
        <stl-vector pointer-type='vehicle' name='order_load' has-bad-pointers='true'/>

        <stl-vector pointer-type='vehicle_ram_graphics_infost' name='ram_graphics_info'/>
    </struct-type>
</data-definition>

