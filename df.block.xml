        <int16_t name='min_x'/>
        <int16_t name='min_y'/>
        <int16_t name='max_x'/>
        <int16_t name='max_y'/>
        <int16_t name='base_z'/>
        <stl-vector type-name='int16_t' name='neighbor_bx'/>
        <stl-vector type-name='int16_t' name='neighbor_by'/>
        <stl-vector type-name='uint16_t' name='neighbor_index'/>
        <bitfield base-type='uint32_t' type-name='cave_column_rectangle_flag' name='flags' original-name='flag'/>

        <virtual-methods>
            <vmethod name='write_file'> <pointer type-name='file_compressorst' name='filecomp'/> </vmethod>
            <vmethod name='read_file'>
                <pointer type-name='file_compressorst' name='filecomp'/>
                <enum type-name='save_version' name='loadversion'/>
            </vmethod>
        </virtual-methods>
    </class-type>

    <struct-type type-name='block_column_print_infost'>
        <static-array name='x' count='4' type-name='int16_t'/>
        <static-array name='y' count='4' type-name='int16_t'/>
        <static-array name='tile' original-name='character' count='4' type-name='uint8_t'/>
    </struct-type>

    <enum-type type-name='map_block_column_flags' original-name='block_column_flag_type'> bay12: BlockColumnFlagType
        <enum-item name='UPDATE_CAVE_COLUMNS'/>
    </enum-type>

    <struct-type type-name='map_block_column' original-name='block_columnst'>
        <int16_t name="sink_level" original-name='water_el_table_block' comment='water at or above this level sinks into aquifer tiles'/>
        <int16_t name="beach_level" original-name='water_el_sink_height' comment='water at this level disappears if above more water'/>

        <int16_t name='ground_level' original-name='central_el_z' comment='for coloring unallocated blocks'/>

        <stl-vector pointer-type='block_column_print_infost' name='unmined_glyphs' original-name='print_info'/>
        <int16_t name="z_base" original-name='print_info_start_el_z'/>

        <static-array name='cave_columns' original-name='cave_column' count='16'>
            <static-array count='16'>
                <df-linked-list type-name='cave_column_link'/>
            </static-array>
        </static-array>

        <stl-vector pointer-type='cave_column_rectangle' name='column_rectangles' original-name='cave_column_rectangle'/>

        <int16_t name='z_shift' original-name='base_z' comment='seems to be 0 originally, but updated when map is shifted'/>

        <df-flagarray name='flags' original-name='flag' index-enum='map_block_column_flags'/>

        <static-array name='elevation' original-name='abs_el_z' count='16' since='v0.40.01'>
