<data-definition>
    <bitfield-type type-name='block_flags' original-name='block_flag' base-type='uint32_t'> bay12: BLOCKFLAG_*
        <flag-bit name='designated' original-name='HAS_DESJOB' comment='for jobs etc'/>
        <flag-bit name='update_temperature' original-name='TEMPERATURE_ADJUST'/>
        <flag-bit name='update_liquid' original-name='FLOW_ADJUST'/>
        <flag-bit name='update_liquid_twice' original-name='FLOW_MAINTAIN_ADJUST'
                  comment='Protects UpdateLiquid from being cleared the first time.'/>
        <flag-bit name='repath_on_freeze' original-name='STALE_ON_FREEZE'
                  comment='reindex_pathfinding set and flag cleared if temperature below 10000'/>
        <flag-bit name='repath_on_melt' original-name='STALE_ON_MELT'
                  comment='reindex_pathfinding set and flag cleared if temperature above 10000'/>
        <flag-bit name='has_aquifer' original-name='HAS_WATER_TABLE'
                  comment='has at least one "water_table" designation flag'/>
        <flag-bit name='check_aquifer' original-name='NEARBY_WATER_TABLE'
                  comment='has tiles that may get flooded by an adjacent aquifer'/>
        <flag-bit name='may_have_item_spatter' original-name='MAY_HAVE_ITEM_SPATTER'/>
        <flag-bit name='may_have_material_spatter' original-name='MAY_HAVE_MATERIAL_SPATTER' comment="usually mud"/>
        <flag-bit name='has_magma_close' original-name='HAS_MAGMA_CLOSE'/>
        <flag-bit name='has_magma_far' original-name='HAS_MAGMA_FAR'/>
        <flag-bit name='mas_magma_low' original-name='HAS_MAGMA_LOW'/>
        <flag-bit name='has_river_high' original-name='HAS_RIVER_HIGH'/>
        <flag-bit name='has_river_medium' original-name='HAS_RIVER_MEDIUM'/>
        <flag-bit name='has_river_low' original-name='HAS_RIVER_LOW'/>
    </bitfield-type>

    <enum-type type-name='block_square_event_type' base-type='int16_t'> bay12: BlockSquareEventType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='mineral' original-name='MINERAL'/>
        <enum-item name='frozen_liquid' original-name='FROZEN_LIQUID'/>
        <enum-item name='world_construction' original-name='WORLD_CONSTRUCTION'/>
        <enum-item name='material_spatter' original-name='MATERIAL_SPATTER'/>
        <enum-item name='grass' original-name='GRASS'/>
        <enum-item name='spoor' original-name='SPOOR'/>
        <enum-item name='item_spatter' original-name='ITEM_SPATTER'/>
        <enum-item name='designation_priority' original-name='DESIGNATION_PRIORITY'/>
    </enum-type>

    <class-type type-name='block_square_event' original-name='block_square_eventst'>
        <virtual-methods>
            <vmethod ret-type='block_square_event_type' name='getType' original-name='type'/>
