        </static-array>

        <int16_t name='minimum_river_z'/>

        <compound type-name='coord' name='map_pos' original-name='start' comment='top left in tiles'/>
        <compound type-name='coord2d' name='region_pos' original-name='a'/>

        <stl-vector pointer-type='plant' name='plants' original-name='veg' comment="Only populated for the top left column in each mid level tile"/>
    </struct-type>
