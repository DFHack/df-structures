<data-definition>
    <enum-type type-name='scale_type' original-name='scale_foundation_type' base-type='int32_t'> bay12: ScaleFoundationType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Octave' original-name='OCTAVE_OF_EVENLY_SPACED_NOTES' comment="The octave is divided into X steps of even length"/>
        <enum-item name='Variable' original-name='OCTAVE_OF_UNEVENLY_SPACED_NOTES' comment="The octave is divided into notes at varying intervals, approximated by quartertones"/>
        <enum-item name='PerfectFourth' original-name='DIVISION_OF_PERFECT_FOURTH' comment="The perfect fourth interval is divided into steps of even length"/>
    </enum-type>

    <bitfield-type type-name='scale_chord_flag' base-type='uint32_t'> bay12: SCALE_CHORD_FLAG_*
        <flag-bit comment='lower' original-name='LOWER'/>
    </bitfield-type>

    <struct-type type-name='chord' original-name='scale_chordst'>
        <stl-string name='name'/>
        <static-array name='notes' original-name='note_index' type-name='int32_t' count='5' comment="chord_size entries used. Refers to the notes indices"/>
        <int32_t name='chord_size' original-name='note_number'/>
        <bitfield base-type='uint32_t' name='flags' original-name='flag' type-name='scale_chord_flag'/>
    </struct-type>

    <enum-type type-name='scale_construction_type' base-type='int32_t'> bay12: ScaleConstructionType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='ByInterval' original-name='BY_INTERVAL'/>
        <enum-item name='PerfectFifthJoinedPerfectFourth' original-name='PERFECT_FIFTH_JOINED_PERFECT_FOURTH'/>
        <enum-item name='PerfectFifthHalfMajorThird' original-name='PERFECT_FIFTH_HALF_MAJOR_THIRD'/>
        <enum-item name='TritoneHalfPercentFourth' original-name='TRITONE_HALF_PERFECT_FOURTH'/>
        <enum-item name='PerfectFourthWholePerfectFourth' original-name='PERFECT_FOURTH_WHOLE_PERFECT_FOURTH'/>
    </enum-type>

    <struct-type type-name='named_scale' original-name='scale_constructionst'>
        <enum name='type' type-name='scale_construction_type'/>
        <stl-string name='name'/>
        <static-array name='degrees' original-name='note_choice' type-name='int32_t' count='7' comment="indices into the (not necessarily named) notes of the scale"/>
        <int32_t name='degrees_used' original-name='note_number' comment="elements used in array above"/>
        <static-array name='chord_index' type-name='int32_t' count='2'/>
    </struct-type>

    <enum-type type-name='scale_naming_type' base-type='int32_t'> bay12: ScaleNamingType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='EveryNote' original-name='EVERY_NOTE'/>
        <enum-item name='PreferredNotes' original-name='PREFERRED_NOTES'/>
        <enum-item name='EveryNoteAfterConstructionByDegree' original-name='EVERY_NOTE_AFTER_CONSTRUCTION_BY_DEGREE'/>
        <enum-item name='PreferredNoteAfterConstructionByDegree' original-name='PREFERRED_NOTE_AFTER_CONSTRUCTION_BY_DEGREE'/>
    </enum-type>

    <struct-type type-name='scale_namingst'>
        <enum name='type' type-name='scale_naming_type'/>
        <static-array name='name' type-name='stl-string' count='25'/>
        <static-array name='abreviation' type-name='stl-string' count='25'/>
        <static-array name='number' original-name='note_index_degree' type-name='int32_t' count='25'/>
        <int32_t name='length' original-name='name_num' comment='number of elements of the arrays above used'/>
    </struct-type>

    <bitfield-type type-name='scale_flag' base-type='uint32_t'> bay12: SCALE_FLAG_*
        <flag-bit name='tonic_note_fixed_at_performance' original-name='MOVEABLE_TONIC'/>
    </bitfield-type>

    <struct-type type-name='scale' original-name='scalest' instance-vector='$global.world.scales.all' key-field='id'>
        <int32_t name='id' original-name='global_id'/>

        <bitfield name='flags' original-name='flag' base-type='uint32_t' type-name='scale_flag'/>

        <enum name='type' original-name='foundation' type-name='scale_type' base-type='int32_t'/>
        <static-array name='quartertones_used' original-name='foundation_quartertone_spacing' type-name='int32_t' count='25' comment="Quartertone corresponding note matches. Scale_length elements are used when type = Variable. Unused elements uninitialized"/>
        <int32_t name='scale_length' original-name='foundation_num' comment="Number of notes in the scale. When type = Variable this is the number of used indices pointing out their placement."/>

        <stl-vector name='chords' original-name='chord' pointer-type='chord'/>
        <stl-vector name='scales' original-name='construction' pointer-type='named_scale' comment="Note that the top level scale doesn't have a name. These seem to be named scales using the unnamed scale's notes as their foundation"/>
        <compound name='notes' original-name='naming' type-name='scale_namingst'/>
    </struct-type>

    <struct-type type-name='scale_handlerst'>
        <stl-vector name='all' original-name='global' pointer-type='scale'/>

        <stl-vector name='order_load' pointer-type='scale' has-bad-pointers='true'/>
    </struct-type>
</data-definition>

