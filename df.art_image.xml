<data-definition>
    <class-type type-name='art_image_element' original-name='art_image_elementst'>
        <int32_t name='count' original-name='amount'/>

        <virtual-methods>
            <vmethod name='write_file'> <pointer type-name='file_compressorst' name='filecomp'/> </vmethod>
            <vmethod name='read_file'>
                <pointer type-name='file_compressorst' name='filecomp'/>
                <enum type-name='save_version' name='loadversion'/>
            </vmethod>
            <vmethod ret-type='art_image_element_type' name='getType' original-name='type'/>
            <vmethod name='setID' original-name='set_subtype'> <int32_t name='st' comment='race, item type, plant ID, or shape ID'/> </vmethod>
            <vmethod is-destructor='true'/>

            <vmethod name='clone' original-name='copy'>
                <ret-type><pointer type-name='art_image_element'/></ret-type>
            </vmethod>
            <vmethod name='getSymbol' original-name='get_pic_info'>
                <pointer type-name='uint8_t' name='pic'/>
                <pointer type-name='int32_t' name='priority'/>
            </vmethod>
            <vmethod name='getName' original-name='get_string'>
                <pointer type-name='stl-string' name='str'/>
                <bool name='definite'/>
                <bool name='full_desc'/>
                <bool name='do_markup'/>
            </vmethod>
            <vmethod name='getShortName' original-name='get_short_string'>
                <pointer type-name='stl-string' name='str'/>
                <bool name='definite'/>
            </vmethod>
            <vmethod name='getGraphicsInfo' original-name='get_graphics_type_id'>
                <pointer type-name='int32_t' name='graphics_type'/>
                <pointer type-name='int32_t' name='graphics_id'/>
            </vmethod>
            <vmethod name='markDiscovered' original-name='reveal_art'/>

            <vmethod name='getColorAndShape' original-name='get_shape_color'>
                <pointer name='i_color'><stl-vector type-name='int16_t'/></pointer>
                <pointer name='i_shape'><stl-vector type-name='int16_t'/></pointer>
            </vmethod>
        </virtual-methods>
    </class-type>

    <class-type type-name='art_image_element_creaturest' inherits-from='art_image_element'>
        <int32_t name='race' ref-target='creature_raw'/>
        <int16_t name='caste'/>
        <int32_t name='histfig' original-name='hfid' ref-target='historical_figure'/>
    </class-type>

    <class-type type-name='art_image_element_itemst' inherits-from='art_image_element'>
        <enum base-type='int16_t' type-name='item_type' name='item_type' original-name='i_type'/>
        <int16_t name='item_subtype' original-name='i_subtype' refers-to='(item-subtype-target $$._parent.item_type $)'/>
        <int16_t name='mat_type' original-name='subcat1' ref-target='material' aux-value='$$.mat_index'/>
        <int16_t name='mat_index' original-name='subcat2'/>
        <bitfield base-type='uint32_t' type-name='item_flags' name='flags' original-name='i_flag'/>
        <int32_t name='item_id' original-name='artifact_itemid' ref-target='item'/>
    </class-type>

    <class-type type-name='art_image_element_plantst' inherits-from='art_image_element'>
        <int32_t name='plant_id' original-name='race' ref-target='plant_raw'/>
    </class-type>

    <class-type type-name='art_image_element_treest' inherits-from='art_image_element'>
        <int32_t name='plant_id' original-name='race' ref-target='plant_raw'/>
    </class-type>

    <class-type type-name='art_image_element_shapest' inherits-from='art_image_element'>
        <int32_t name='shape_id' original-name='shape_index' ref-target='descriptor_shape'/>
        <int16_t name='shape_adj' original-name='shape_adj_index'/>
    </class-type>

    <enum-type type-name='art_image_property_type'> bay12: ArtImageProperty
        <enum-item name="NONE" value='-1'/>
        <enum-item name="transitive_verb" original-name='TRANSITIVE_VERB'/>
        <enum-item name="intransitive_verb" original-name='INTRANSITIVE_VERB'/>
    </enum-type>

    <class-type type-name='art_image_property' original-name='art_image_propertyst'>
        <df-flagarray name='flags' original-name='flag' comment='currently none used'/>

        <virtual-methods>
            <vmethod name='write_file'> <pointer type-name='file_compressorst' name='filecomp'/> </vmethod>
            <vmethod name='read_file'>
                <pointer type-name='file_compressorst' name='filecomp'/>
                <enum type-name='save_version' name='loadversion'/>
            </vmethod>
            <vmethod ret-type='art_image_property_type' name='getType' original-name='type'/>
            <vmethod is-destructor='true'/>
            <vmethod name='clone' original-name='copy'>
                <ret-type><pointer type-name='art_image_element'/></ret-type>
            </vmethod>

            <vmethod name='getName' original-name='get_string'>
                <pointer type-name='stl-string' name='str'/>
                <pointer type-name='art_image' name='im'/>
                <bool name='full_desc'/>
                <bool name='do_markup'/>
            </vmethod>
        </virtual-methods>
    </class-type>

    <class-type type-name='art_image_property_transitive_verbst' inherits-from='art_image_property'>
        <int32_t name='subject' original-name='actor_element_index'/>
        <int32_t name='object' original-name='target_element_index'/>
        <enum base-type='int16_t' type-name='art_image_property_verb' name="verb" original-name='action'/>
    </class-type>

    <class-type type-name='art_image_property_intransitive_verbst' inherits-from='art_image_property'>
        <int32_t name='subject' original-name='actor_element_index'/>
        <enum base-type='int16_t' type-name='art_image_property_verb' name="verb" original-name='action'/>
    </class-type>

    <struct-type type-name='art_image' original-name='art_imagest'>
        <code-helper name='find-instance'>$(find-instance $art_image_chunk $$).images[$]</code-helper>
        <code-helper name='describe'>(describe-obj $.name)</code-helper>

        <stl-vector pointer-type='art_image_element' name='elements' original-name='element'/>
        <stl-vector pointer-type='art_image_property' name='properties' original-name='property'/>

        <int32_t name='event' original-name='hist_event_id' ref-target='history_event'/>
        <compound type-name='language_name' name='name'/>

        <enum base-type='int32_t' type-name='specific_ref_type' name='spec_ref_type' original-name='reftype'/>
        <int16_t name='mat_type' original-name='mat' ref-target='material' aux-value='$$.mat_index'/>
        <int32_t name='mat_index' original-name='matg'/>
        <enum base-type='int16_t' type-name='item_quality' name='quality' original-name='cq'/>
        <int32_t name='artist' original-name='artist_hfid' ref-target='historical_figure'/>
        <int32_t name='site' original-name='creation_site_id' ref-target='world_site'/>

        <pointer type-name='general_ref' name='ref' original-name='substrate'/>
        <int32_t name='year'/>
        <int32_t name='season_tick' original-name='season_count'/>

        <int32_t name='id' original-name='chunk' ref-target='art_image_chunk'/>
        <int16_t name='subid' original-name='chunk_member' ref-target='art_image' aux-value='$$.id'/>
    </struct-type>

    <struct-type type-name='art_image_chunk_memberst'>
        <pointer type-name='art_image' name='art_image'/>
    </struct-type>

    <struct-type type-name='art_image_chunk' original-name='art_image_chunkst'
                 instance-vector='$global.world.art_image_chunks.all' key-field='id'>
        <int32_t name='id' original-name='global_id' comment='art_image_*.dat'/>

        <static-array name='images' original-name='member' count='500' type-name='art_image_chunk_memberst'/>
    </struct-type>

    <struct-type type-name='art_image_chunk_handlerst'>
        <stl-vector pointer-type='art_image_chunk' name='all' original-name='global'/>
    </struct-type>
</data-definition>

