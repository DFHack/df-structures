<data-definition>
    <bitfield-type type-name='wilderpop_flag' base-type='uint8_t'> bay12: WILDERPOPFLAG_*
        <flag-bit name='discovered' original-name='DISCOVERED'/>
        <flag-bit name='extinct' original-name='NULLIFIED'/>
        <flag-bit name='already_removed' original-name='DIRECT_ERASE' comment='no longer in world.populations'/>
        <flag-bit name='need_offload' original-name='NEED_TO_OFFLOAD'/>
    </bitfield-type>

    <struct-type type-name='local_population' original-name='wilderpopst'>
        <enum base-type='int8_t' name='type' type-name='world_population_type'/>

        <compound is-union='true'> not actually a union, just race
            <int16_t name="race" ref-target='creature_raw'/>
            <int16_t name="plant" ref-target='plant_raw'/>
        </compound>

        <int32_t name="quantity" original-name='number'/>
        <int32_t name="quantity_max" original-name='max_number' since='v0.40.01'/>

        <bitfield name='flags' original-name='flag' base-type='uint8_t' type-name='wilderpop_flag'/>

        <compound name='population' original-name='rpop_info' type-name='world_population_ref'/>

        <int32_t name="breed" original-name='breed_id' ref-target='breed'/>

        <int32_t name='interaction_idx' original-name='interaction_index' init-value='-1'/>
        <int32_t name='interaction_instance' original-name='interaction_instance_id' init-value='-1'/>
        <int32_t name='interaction_effect' original-name='interaction_effect_id' init-value='-1'/>
    </struct-type>

    <struct-type type-name='wilderpop_handlerst'>
        <stl-vector name='all' original-name='play' pointer-type='local_population'/>
    </struct-type>
</data-definition>

