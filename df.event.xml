<data-definition>
    <bitfield-type type-name='engraving_flags' original-name='event_detail_flag' base-type='uint32_t'> bay12: EVENTDETAILFLAG_*
        <flag-bit name='floor' original-name='FLOOR'/>
        <flag-bit name='west' original-name='WEST'/>
        <flag-bit name='east' original-name='EAST'/>
        <flag-bit name='north' original-name='NORTH'/>
        <flag-bit name='south' original-name='SOUTH'/>
        <flag-bit name='hidden' original-name='OBSCURED'/>
        <flag-bit name='northwest' original-name='NW'/>
        <flag-bit name='northeast' original-name='NE'/>
        <flag-bit name='southwest' original-name='SW'/>
        <flag-bit name='southeast' original-name='SE'/>
    </bitfield-type>

    <struct-type type-name='engraving' original-name='event_detailst' instance-vector='$global.world.event.engravings'>
        <int32_t name='artist' original-name='artist_hfid' ref-target='historical_figure'/>
        <int32_t name='masterpiece_event' original-name='creation_heid' ref-target='history_event'/>
        <enum base-type='int32_t' name="skill_rating" original-name='skill_at_time' type-name='skill_rating'/>
        <compound name='pos' type-name='coord'/>
        <bitfield name='flags' original-name='flag' type-name='engraving_flags'/>
        <uint8_t name='tile' original-name='pic'/>
        <int32_t name='art_id' original-name='image_chunk_id' ref-target='art_image_chunk'/>
        <int16_t name='art_subid' original-name='image_chunk_member' ref-target='art_image' aux-value='$$.art_id'/>
        <enum base-type='int16_t' name='quality' original-name='craftquality' type-name='item_quality'/>
        <int32_t name='art_civ' original-name='art_gen_enid' ref-target='historical_entity' since='v0.34.06'/>
        <int32_t name='art_site' original-name='art_gen_stid' ref-target='world_site' since='v0.34.06'/>
    </struct-type>

    <struct-type type-name='glowing_barrier' original-name='event_underworld_building_monitorst'>
        <uint8_t name='triggered' comment='set when the glowing barrier vanishes, preventing later HFS events'/>
        <int32_t name='age' original-name='buildup' comment='divide by 100800, add 1, then multiply by 20 to get number of demons to summon (min 10, max 100)'/>
        <stl-vector name='buildings' original-name='building_id' type-name='int32_t' ref-target='building' comment='when building is deconstructed, causes glowing barrier at pos to vanish and (in fort mode) spawns HFS one z-level below if it has not been set off already'/>
        <compound name='pos' original-name='center' type-name='coord' comment='coordinates of a GlowingBarrier or GlowingFloor tiletype'/>
    </struct-type>

    <struct-type type-name='deep_vein_hollow' original-name='event_underworld_tube_breach_monitorst'>
        <uint8_t name='triggered' comment='set when the underworld spire is breached, preventing subsequent HFS events'/>
        <int32_t name='age' original-name='buildup' comment='divide by 100800, add 1, then multiply by 20 to get number of demons to summon (min 10, max 100)'/>
        <compound name='tiles' original-name='trigger' type-name='coord_path' comment='tile coordinates correspond to open spaces within an underworld spire; revealing one of these tiles triggers the HFS demon wave'/>
        <compound name='pos' original-name='cur_trigger' type-name='coord' comment='announcement zoom location'/>
    </struct-type>

    <struct-type type-name='divine_treasure' original-name='event_tube_treasure_monitorst'>
        <int32_t name='histfig_id' original-name='source_hfid' ref-target='historical_figure'/>
        <enum type-name='item_type' name='item_type' original-name='i_type'/>
        <int16_t name='item_subtype' original-name='i_subtype'/>
        <int16_t name='mat_type' original-name='sc1'/>
        <int32_t name='mat_index' original-name='sc2'/>
        <uint8_t name='triggered'/>
        <compound type-name='coord_path' name='tiles' original-name='trigger'/>
        <compound type-name='coord' name='pos' original-name='cur_trigger' comment='announcement zoom location'/>
    </struct-type>

    <enum-type type-name='tube_hazard_type' base-type='int32_t'> bay12: TubeHazardType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='ENEMY'/>
        <enum-item name='FLOW'/>
    </enum-type>

    <struct-type type-name='encased_horror' original-name='event_tube_hazard_monitorst'>
        <enum name='type' type-name='tube_hazard_type'/>
        <int32_t name='race'/>
        <int32_t name='caste'/>
        <int32_t name='source_hf' original-name='source_hfid' ref-target='historical_figure'/>
        <int32_t name='flow'/>
        <int32_t name='flow_st'/>
        <int32_t name='flow_sst'/>
        <uint8_t name='triggered'/>
        <compound type-name='coord_path' name='tiles' original-name='trigger'/>
        <compound type-name='coord' name='pos' original-name='cur_trigger' comment='announcement zoom location'/>
    </struct-type>

    <struct-type type-name='edm_rectst'>
        <int32_t name='x_min' original-name='min_x'/>
        <int32_t name='y_min' original-name='min_y'/>
        <int32_t name='z_min' original-name='min_z'/>
        <int32_t name='x_max' original-name='max_x'/>
        <int32_t name='y_max' original-name='max_y'/>
        <int32_t name='z_max' original-name='max_z'/>
    </struct-type>

    <struct-type type-name='cursed_tomb' original-name='event_disturbance_monitorst'>
        <uint8_t name='triggered'/>
        <stl-vector type-name='int32_t' name='coffin_skeletons' original-name='corpse_item_id' ref-target='item' comment='binary'/>
        <int32_t name='disturbance' original-name='interaction_index' ref-target='interaction'/>
        <stl-vector type-name='int32_t' name='treasures' original-name='disturb_item_id' ref-target='item' comment='binary'/>
        <int32_t name='site_id' ref-target='world_site'/>
        <int32_t name='structure_id' original-name='ab_id' ref-target='abstract_building'/>
        <stl-vector name='trigger_regions' original-name='rectangle' pointer-type='edm_rectst' comment='normally just one, 3x3 around the coffin'/>
        <compound type-name='coord' name='coffin_pos' original-name='center'/>
    </struct-type>

    <bitfield-type type-name='vermin_flags' original-name='vermin_event_flag' base-type='uint32_t'> bay12: VERMINEVENTFLAG_*
        <flag-bit name='already_deleting' original-name='ALREADYDELLING'/>
        <flag-bit name='is_colony' original-name='COLONY' comment='A vermin colony. For example an anthill or bee hive.'/>
        <flag-bit name='triggerable' original-name='TRIGGERABLE'/>
        <flag-bit name='is_roaming_colony' original-name='NOT_LIMITING' comment="colony building vermin away from colony"/>
    </bitfield-type>

    <enum-type type-name='vermin_category' original-name='vermin_creature_type'> bay12: VerminCreationType
        <enum-item name='None' original-name='NONE' value='-1'/>
        <enum-item name='Eater' original-name='EATER'/>
        <enum-item name='Grounder' original-name='GROUNDER'/>
        <enum-item name='Rotter' original-name='ROTTER'/>
        <enum-item name='Swamper' original-name='SWAMPER'/>
        <enum-item name='Colony' original-name='COLONY'/>
        <enum-item name='Triggered' original-name='TRIGGERED'/>
        <enum-item name='Item' original-name='ITEM'/>
        <enum-item name='Sphere' original-name='SPHERE'/>
        <enum-item name='FromColony' original-name='FROM_COLONY'/>
    </enum-type>

    <struct-type type-name='vermin' original-name='event_verminst' instance-vector='$global.world.event.vermin'>
        <int16_t name='race' ref-target='creature_raw'/>
        <int16_t name='caste' ref-target='caste_raw' aux-value='$$.race'/>
        <compound name='pos' type-name='coord'/>
        <bool name="visible" comment="1 = visible vermin" />

        <int16_t name="countdown" original-name='fuel'/>

        <pointer name="item" original-name='it' type-name='item'/>

        <bitfield name='flags' original-name='flag' type-name='vermin_flags'/>
        <int32_t name="amount" original-name='number' comment="The total number of vermin in this object. Decimal constant 10000001 means infinity (probably)." />

        <compound name='population' original-name='rpop_info' type-name='world_population_ref'/>

        <enum type-name='vermin_category' base-type='int16_t' name='category' original-name='creation_type'/>
        <int32_t name='id' original-name='save_index' comment='assigned during Save'/>
    </struct-type>

    <struct-type type-name='event_waterst'>
        <compound type-name='coord' name='pos'/>
    </struct-type>

    <struct-type type-name='web_cluster' original-name='event_webst'>
        <stl-vector type-name='int16_t' name='x'/>
        <stl-vector type-name='int16_t' name='y'/>
        <int16_t name='z'/>
        <int16_t name='race' ref-target='creature_raw'/>
        <int16_t name='caste' ref-target='caste_raw' aux-value='$$.race' />
        <compound type-name='coord2d' name='pos_min' original-name='min'/>
        <compound type-name='coord2d' name='pos_max' original-name='max'/>
        <stl-vector type-name='int32_t' name='ambushers' original-name='webber' ref-target='unit'/>
    </struct-type>

    <struct-type type-name='campfire' original-name='event_campfirest'>
        <compound type-name='coord' name='pos'/>
        <int32_t name='timer' original-name='stoked'/>
    </struct-type>

    <struct-type type-name='fire' original-name='event_firest'>
        <compound type-name='coord' name='pos'/>
        <int16_t name='timer' original-name='duration'/>
        <uint16_t name='inner_temp_cur' original-name='local_heat' init-value='10508' comment='applied to own tile'/>
        <uint16_t name='outer_temp_cur' original-name='adj_heat' init-value='10000' comment='applied to neighboring tiles'/>
        <uint16_t name='inner_temp_max' original-name='local_heat_max' init-value='10708'/>
        <uint16_t name='outer_temp_max' original-name='adj_heat_max' init-value='10708'/>
    </struct-type>

    <struct-type type-name='coord_rect' original-name='event_swampst'>
        <int16_t name='x1' original-name='sx'/>
        <int16_t name='y1' original-name='sy'/>
        <int16_t name='x2' original-name='ex'/>
        <int16_t name='y2' original-name='ey'/>
        <int16_t name='z'/>
    </struct-type>

    <struct-type type-name='ocean_wave_maker' original-name='event_ocean_wave_generatorst'>
        <compound type-name='coord' name='pos'/>
        <int8_t name='interval' original-name='duration'/>
        <compound name='coastline' original-name='s_point' type-name='coord2d_path'/>
        <compound name='wave_origin' original-name='o_point' type-name='coord2d_path'/>
    </struct-type>

    <struct-type type-name='ocean_wave' original-name='event_ocean_wave_frontst'>
        <compound type-name='coord2d' name='dest' original-name='g'/>
        <compound type-name='coord2d' name='cur' original-name='s'/>
        <int16_t name='z'/>
        <int8_t name='spawn_flows' original-name='active' comment='set once the wave reaches the coast'/>
        <int8_t name='move_timer' original-name='duration'/>
        <int8_t name='vis_duration' original-name='visdur' comment='starts at 120 and randomly decrements'/>
    </struct-type>

    <bitfield-type type-name='construction_flags' original-name='event_construction_flag' base-type='uint8_t'> bay12: EVENT_CONSTRUCTION_FLAG_*
        <flag-bit name='no_build_item' original-name='MUST_GENERATE_ITEMS' comment='build item is created from scratch upon removing construction, does not exist beforehand'/>
        <flag-bit name='top_of_wall' original-name='ITEMLESS_CEILING' comment='used on the floors above constructed walls so you cannot remove them'/>
        <flag-bit name='reinforced' original-name='REINFORCED'/>
    </bitfield-type>

    <struct-type type-name='construction' instance-vector='$global.world.event.constructions' key-field='pos' original-name='event_constructionst' custom-methods='true'>
        <compound name='pos' type-name='coord'/>
        <enum type-name='item_type' original-name='i_type' name='item_type'/>
        <int16_t name='item_subtype' original-name='i_subtype' refers-to='(item-subtype-target $$._parent.item_type $)'/>
        <int16_t name='mat_type' original-name='i_sc1' ref-target='material' aux-value='$$.mat_index'/>
        <int32_t name='mat_index' original-name='i_sc2'/>
        <bitfield type-name='construction_flags' name='flags' original-name='flag'/>
        <enum base-type='uint16_t' type-name='tiletype' name='original_tile' original-name='old_tile'/>
        <int16_t name='sec_i_sc1' ref-target='material' aux-value='$$.sec_i_sc2'/>
        <int32_t name='sec_i_sc2'/>
    </struct-type>

    <struct-type type-name='embark_feature' original-name='event_populationst' comment="layers plus river seen">
        <compound type-name='coord2d' name='world_tile' original-name='a'/>
        <compound type-name='coord2d' name='mid_level_tile' original-name='d' comment="the MLT the feature resides in"/>
        <int16_t name='local_feature_idx' original-name='feature_ind'/>
        <int32_t name='global_feature_idx' original-name='feature_layer' ref-target='world_underground_region'/>
        <int32_t name='global_feature_sq' original-name='feature_layer_sq'/>
        <enum name='layer' original-name='layer_depth' type-name='layer_type' base-type='int16_t'/>
        <compound type-name='coord2d' name='local' original-name='s' comment="the top left corner of the MLT, in embark relative coordinates"/>
        <int16_t name='z_min' original-name='min_z'/>
        <int16_t name='z_max' original-name='max_z'/>
    </struct-type>

    <struct-type type-name='event_handlerst'>
        <stl-vector name='glowing_barriers' original-name='underworld_building_monitor' pointer-type='glowing_barrier'/>
        <stl-vector name='deep_vein_hollows' original-name='underworld_tube_breach_monitor' pointer-type='deep_vein_hollow'/>
        <stl-vector name='divine_treasures' original-name='tube_treasure_monitor' pointer-type='divine_treasure'/>
        <stl-vector name='encased_horrors' original-name='tube_hazard_monitor' pointer-type='encased_horror'/>
        <stl-vector name='cursed_tombs' original-name='disturbance_monitor' pointer-type='cursed_tomb'/>
        <stl-vector name='engravings' original-name='detail' pointer-type='engraving'/>
        <stl-vector name='vermin' pointer-type='vermin'/>
        <stl-vector name='vermin_colonies' original-name='vermin_colony' pointer-type='vermin'/>
        <stl-vector name='dirty_waters' original-name='water' pointer-type='event_waterst' comment="for making blood flow downstream in rivers, but also includes mud in artificial water channels"/>
        <stl-vector name='campfires' original-name='campfire' pointer-type='campfire'/>
        <stl-vector name='web_clusters' original-name='web' pointer-type='web_cluster'/>
        <stl-vector name='fires' original-name='fire' pointer-type='fire'/>
        <stl-vector name='ocean_wave_makers' original-name='ocean_wave_generator' pointer-type='ocean_wave_maker'/>
        <stl-vector name='ocean_waves' original-name='ocean_wave_front' pointer-type='ocean_wave'/>
        <stl-vector name='constructions' original-name='construction' pointer-type='construction'/>
        <stl-vector name='murky_pools' original-name='swamp' pointer-type='coord_rect'/>
        <stl-vector name='embark_features' original-name='population' pointer-type='embark_feature' comment="populated at embark"/>

        <!-- bay12: "THESE ARE USED DURING SITE SAVE/LOAD" -->
        <stl-vector name='temp_save_glowing_barriers' original-name='temp_save_underworld_building_monitor' pointer-type='glowing_barrier'/>
        <stl-vector name='temp_save_deep_vein_hollows' original-name='temp_save_underworld_tube_breach_monitor' pointer-type='deep_vein_hollow'/>
        <stl-vector name='temp_save_divine_treasures' original-name='temp_save_tube_treasure_monitor' pointer-type='divine_treasure'/>
        <stl-vector name='temp_save_encased_horrors' original-name='temp_save_tube_hazard_monitor' pointer-type='encased_horror'/>
        <stl-vector name='temp_save_cursed_tombs' original-name='temp_save_disturbance_monitor' pointer-type='cursed_tomb'/>
        <stl-vector name='temp_save_engravings' original-name='temp_save_detail' pointer-type='engraving'/>
        <stl-vector name='temp_save_constructions' original-name='temp_save_construction' pointer-type='construction'/>
        <stl-vector name='temp_save_embark_features' original-name='temp_save_population' pointer-type='embark_feature'/>
        <stl-vector name='temp_save_ocean_wave_makers' original-name='temp_save_ocean_wave_generator' pointer-type='ocean_wave_maker'/>
        <stl-vector name='temp_save_murky_pools' original-name='temp_save_swamp' pointer-type='coord_rect'/>
    </struct-type>
</data-definition>

