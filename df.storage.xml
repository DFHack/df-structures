<data-definition>
    -- Not an actual enum
    <enum-type type-name='hauler_type'>
        <enum-item name='Any' original-name='all'/>
        <enum-item name='Stone' original-name='mining'/>
        <enum-item name='Wood' original-name='wood'/>
        <enum-item name='Item' original-name='burial'/>
        <enum-item name='Bin' original-name='item'/>
        <enum-item name='Body' original-name='body'/>
        <enum-item name='Food' original-name='food'/>
        <enum-item name='Refuse' original-name='refuse'/>
        <enum-item name='Furniture' original-name='furniture'/>
        <enum-item name='Animal' original-name='animals'/>
    </enum-type>

    <struct-type type-name='storage_handlerst'>
        -- Not really arrays, actually just individual integers following the fake enum above
        <static-array type-name='int32_t' name='num_jobs' original-name='storage_job_num' count='10' index-enum='hauler_type'/>
        <static-array type-name='int32_t' name='num_haulers' original-name='hauler_num' count='10' index-enum='hauler_type'/>

        <int8_t name='barreltype'/>
        <int8_t name='barreltype_food'/>
        <stl-vector type-name='int8_t' name='seeds' original-name='barreltype_seedbag'
                    index-refers-to='(find-plant-raw $)'/>
        <stl-vector type-name='int8_t' name='plants' original-name='barreltype_plant'
                    index-refers-to='(find-plant-raw $)'/>
        <stl-vector type-name='int8_t' name='cheese' original-name='barreltype_cheese'
                    index-refers-to='(find-creature $)'/>
        <stl-vector type-name='int8_t' name='meat_fish' original-name='barreltype_meat_fish'
                    index-refers-to='(find-creature $)'/>
        <stl-vector type-name='int8_t' name='eggs' original-name='barreltype_egg'
                    index-refers-to='(find-creature $)'/>
        <stl-vector type-name='int8_t' name='leaves' original-name='barreltype_leafbag'
                    index-refers-to='(find-plant-raw $)'/>
        <stl-vector type-name='int8_t' name='plant_powder' original-name='barreltype_powder_misc_bag'
                    index-refers-to='(find-plant-raw $)'/>
        <int8_t name='barreltype_seeds_mix' original-name='barreltype_seedbag_mix'/>
        <int8_t name='barreltype_plants_mix' original-name='barreltype_plant_mix'/>
        <int8_t name='barreltype_cheese_mix'/>
        <int8_t name='barreltype_fish_mix'/>
        <int8_t name='barreltype_meat_mix'/>
        <int8_t name='barreltype_leaves_mix' original-name='barreltype_leafbag_mix'/>
        <int8_t name='barreltype_powder_mix' original-name='barreltype_powder_misc_bag_mix'/>
        <int8_t name='barreltype_eggs_mix' original-name='barreltype_egg_mix'/>
        <stl-vector type-name='int8_t' name='liquid_plant' original-name='barreltype_extract_plant'
                    index-refers-to='(find-plant-raw $)'/>
        <stl-vector type-name='int8_t' name='liquid_animal' original-name='barreltype_extract_animal'
                    index-refers-to='(find-creature $)'/>
        <stl-vector type-name='int8_t' name='liquid_builtin' original-name='barreltype_liquid_misc'
                    index-refers-to='(material-by-id $ -1)'/>
        <int8_t name='barreltype_glob_fat'/>
        <int8_t name='barreltype_glob_tallow'/>
        <int8_t name='barreltype_glob_paste'/>
        <int8_t name='barreltype_glob_pressed'/>
        <int8_t name='bintype_weapon'/>
        <int8_t name='bintype_armor'/>
        <int8_t name='bintype_ammo'/>
        <int8_t name='bintype_coins'/>
        <int8_t name='bintype_barblock'/>
        <int8_t name='bintype_gem' comment='not large'/>
        <int8_t name='bintype_finished'/>
        <int8_t name='bintype_leather'/>
        <int8_t name='bintype_cloth'/>
        <int8_t name='bintype_sheet'/>
    </struct-type>
</data-definition>

