<data-definition>
    <struct-type type-name='unit_chunk_memberst'>
        <stl-vector pointer-type='item' name='items' original-name='item'/>
        <pointer type-name='unit' name='unit'/>
    </struct-type>

    <struct-type type-name='unit_chunk' original-name='unit_chunkst'
                 instance-vector='$global.world.unit_chunks.all' key-field='id'>
        <int32_t name='id' original-name='global_id' comment='unit_*.dat'/>
        <static-array name='units' original-name='member' count='100' type-name='unit_chunk_memberst'/>
    </struct-type>

    <struct-type type-name='unit_chunk_handlerst'>
        <stl-vector pointer-type='unit_chunk' name='all' original-name='global'/>
    </struct-type>
</data-definition>

