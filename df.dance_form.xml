<data-definition>
    <bitfield-type type-name='dance_flag' base-type='uint32_t'> bay12: DANCE_FLAG_*
        <flag-bit comment='acts_out_story_in_musics_poetry' original-name='ACTS_OUT_STORY_IN_MUSICS_POETRY'/>
    </bitfield-type>

    <enum-type type-name='dance_form_move_type' original-name='dance_component_type' base-type='int32_t'> bay12: DanceComponentType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='SquareStep' original-name='BASIC_MOVEMENT_BOX'/>
        <enum-item name='CircularStep' original-name='BASIC_MOVEMENT_CIRCLE'/>
        <enum-item name='TriangleStep' original-name='BASIC_MOVEMENT_TRIANGLE'/>
        <enum-item name='FigureEightStep' original-name='BASIC_MOVEMENT_FIGURE_EIGHT'/>
        <enum-item name='IntricateStep' original-name='BASIC_MOVEMENT_INTRICATE'/>
        <enum-item name='Dance' original-name='UNIVERSAL'/>
        <enum-item name='Turn' original-name='TURN'/>
        <enum-item name='FacialExpression' original-name='FACIAL_EXPRESSION'/>
        <enum-item name='HandGesture' original-name='HAND_GESTURE'/>
        <enum-item name='StraightWalk' original-name='WALK_STRAIGHT'/>
        --  10
        <enum-item name='CurvedWalk' original-name='WALK_CURVED'/>
        <enum-item name='Run' original-name='RUN'/>
        <enum-item name='Leap' original-name='LEAP'/>
        <enum-item name='Kick' original-name='KICK'/>
        <enum-item name='LeftKick' original-name='KICK_LEFT'/>
        <enum-item name='RightKick' original-name='KICK_RIGHT'/>
        <enum-item name='LegLift' original-name='LEG_LIFT'/>
        <enum-item name='LeftLegLift' original-name='LEG_LIFT_LEFT'/>
        <enum-item name='RightLegLift' original-name='LEG_LIFT_RIGHT'/>
        <enum-item name='BodyLevel' original-name='LEVEL'/>
        --  20
        <enum-item name='BodyLevelChange' original-name='LEVEL_CHANGE'/>
        <enum-item name='ArmCarriage' original-name='ARM_CARRIAGE'/>
        <enum-item name='RaisedLeftArm' original-name='RAISED_ARM_LEFT'/>
        <enum-item name='RaisedRightArm' original-name='RAISED_ARM_RIGHT'/>
        <enum-item name='RaisedArms' original-name='RAISED_ARM_ALL'/>
        <enum-item name='Spin' original-name='SPIN'/>
        <enum-item name='IndependentBodyMovement' original-name='INDEPENDENT_BP_MOVEMENT'/>
        <enum-item name='Sway' original-name='VERTICAL_SWAY'/>
        <enum-item name='ForwardBend' original-name='VERTICAL_BEND_FORWARD'/>
        <enum-item name='BackwardBend' original-name='VERTICAL_BEND_BACK'/>
        --  30
        <enum-item name='LeftwardBend' original-name='VERTICAL_BEND_LEFT'/>
        <enum-item name='RightwardBend' original-name='VERTICAL_BEND_RIGHT'/>
        <enum-item name='Footwork' original-name='FOOTWORK'/>
        <enum-item name='MovementAlongLineOfDance' original-name='BODY_FLIGHT'/>
    </enum-type>

    <enum-type type-name='dance_form_move_modifier' original-name='dance_component_adjective_type' base-type='int32_t'> bay12: DanceComponentAdjectiveType
        <enum-item name='NONE' value='-1'/>
        --  0
        <enum-item name='Graceful' original-name='GRACEFUL'/>
        <enum-item name='Serene' original-name='SERENE'/>
        <enum-item name='Calm' original-name='CALM'/>
        <enum-item name='Grotesque' original-name='GROTESQUE'/>
        <enum-item name='Crude' original-name='CRUDE'/>
        <enum-item name='Refined' original-name='REFINED'/>
        <enum-item name='Understated' original-name='UNDERSTATED'/>
        <enum-item name='Delicate' original-name='DELICATE'/>
        <enum-item name='Elaborate' original-name='ELABORATE'/>
        <enum-item name='Expressive' original-name='EXPRESSIVE'/>
        --  10
        <enum-item name='Strong' original-name='STRONG'/>
        <enum-item name='Large' original-name='LARGE'/>
        <enum-item name='Weightless' original-name='WEIGHTLESS'/>
        <enum-item name='Fluid' original-name='FLUID'/>
        <enum-item name='Undulating' original-name='UNDULATING'/>
        <enum-item name='Soft' original-name='SOFT'/>
        <enum-item name='Jerking' original-name='JERKING'/>
        <enum-item name='SharpEdged' original-name='SHARP_EDGED'/>
        <enum-item name='StraightLined' original-name='STRAIGHT_LINED'/>
        <enum-item name='High' original-name='HIGH'/>
        --  20
        <enum-item name='Low' original-name='LOW'/>
        <enum-item name='LoudlyPercussive' original-name='LOUD_PERCUSSIVE'/>
        <enum-item name='SoftlyPercussive' original-name='SOFT_PERCUSSIVE'/>
        <enum-item name='Aborted' original-name='ABORTED'/>
        <enum-item name='PartiallyRealized' original-name='PARTIALLY_REALIZED'/>
        <enum-item name='Energetic' original-name='ENERGETIC'/>
        <enum-item name='Passionate' original-name='PASSIONATE'/>
        <enum-item name='Vivacious' original-name='VIVACIOUS'/>
        <enum-item name='Joyous' original-name='JOYOUS'/>
        <enum-item name='Proud' original-name='PROUD'/>
        --  30
        <enum-item name='Flamboyant' original-name='FLAMBOYANT'/>
        <enum-item name='Lively' original-name='LIVELY'/>
        <enum-item name='Spirited' original-name='SPIRITED'/>
        <enum-item name='Vigorous' original-name='VIGOROUS'/>
        <enum-item name='Intense' original-name='INTENSE'/>
        <enum-item name='Aggressive' original-name='AGGRESSIVE'/>
        <enum-item name='Powerful' original-name='POWERFUL'/>
        <enum-item name='Sluggish' original-name='SLUGGISH'/>
        <enum-item name='Relaxed' original-name='RELAXED'/>
        <enum-item name='Passive' original-name='PASSIVE'/>
        --  40
        <enum-item name='Subtle' original-name='SUBTLE'/>
        <enum-item name='Sensual' original-name='SENSUAL'/>
        <enum-item name='Debauched' original-name='DEBAUCHED'/>
        <enum-item name='Twisting' original-name='TWISTING'/>
        <enum-item name='Sprightly' original-name='SPRIGHTLY'/>
        <enum-item name='Sinuous' original-name='SINUOUS'/>
    </enum-type>

    <bitfield-type type-name="dance_form_move_location" original-name='dance_component_flag' base-type="uint32_t"> bay12: DANCE_COMPONENT_FLAG_*
        <flag-bit name='SimultaneousWithPrevious' original-name='SIMULTANEOUS_WITH_PREVIOUS'/>
        <flag-bit name='ChainsAfterPrevious' original-name='CHAINS_AFTER_PREVIOUS'/>
        <flag-bit name='MirroredByGroupMembers' original-name='GROUP_MIRRORING'/>
        <flag-bit name='InRetrogradeByGroupMembers' original-name='GROUP_RETROGRADE'/>
        <flag-bit name='InSuccessionByGroupMembers' original-name='GROUP_CANON'/>
        <flag-bit name='ShadowedByGroupMembers' original-name='GROUP_SHADOWING'/>
        <flag-bit name='Lead' original-name='PARTNER_LEADER_ONLY'/>
        <flag-bit name='Follower' original-name='PARTNER_FOLLOWER_ONLY'/>
    </bitfield-type>

    <enum-type type-name='dance_form_group_size' original-name='dance_grouping_type' base-type='int32_t'> bay12: DanceGroupingType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Solo' original-name='SOLO'/>
        <enum-item name='Partner' original-name='PARTNERED'/>
        <enum-item name='Group' original-name='GROUP'/>
    </enum-type>

    <enum-type type-name='dance_form_configuration' original-name='dance_group_shape_type' base-type='int32_t'> bay12: DanceGroupShapeType
        <enum-item name='NONE' value='-1' comment="hard to have a configuration with a solo performer"/>
        <enum-item name='SingleLine' original-name='SINGLE_LINE'/>
        <enum-item name='SeveralLines' original-name='SEVERAL_LINES'/>
        <enum-item name='Circle' original-name='CIRCLE'/>
        <enum-item name='DoubleCircle' original-name='DOUBLE_CIRCLE'/>
        <enum-item name='LooselyMingled' original-name='LOOSELY_MINGLED'/>
    </enum-type>

    <enum-type type-name='dance_form_movement_path' original-name='dance_line_of_dance_type' base-type='int32_t'> bay12: DanceLineOfDanceType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='TurnClockwise' original-name='CIRCLE_CW'/>
        <enum-item name='TurnCounterClockwise' original-name='CIRCLE_CCW'/>
        <enum-item name='ImprovisedPath' original-name='IMPROVISED'/>
        <enum-item name='IntricatePath' original-name='INTRICATE'/>
    </enum-type>

    <enum-type type-name='dance_form_partner_distance' original-name='dance_connection_distance_type' base-type='int32_t'> bay12: DanceConnectionDistanceType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Closely' original-name='CLOSED'/>
        <enum-item name='OpenContact' original-name='OPEN'/>
        <enum-item name='RareContact' original-name='SEPARATED'/>
    </enum-type>

    <enum-type type-name='dance_form_partner_intent' original-name='dance_connection_tension_type' base-type='int32_t'> bay12: DanceConnectionTensionType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='PushingTogether' original-name='PUSH'/>
        <enum-item name='PullingAway' original-name='PULL'/>
        <enum-item name='Touch' original-name='NEUTRAL_GRASP'/>
        <enum-item name='LightTouch' original-name='NEUTRAL_SMALL_GRASP_APPENDAGE'/>
        <enum-item name='VisualCues' original-name='VISUAL'/>
        <enum-item name='SpokenCues' original-name='SPOKEN'/>
    </enum-type>

    <enum-type type-name='dance_form_partner_cue_frequency' original-name='dance_connection_time_type' base-type='int32_t'> bay12: DanceConnectionTimeType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Constantly' original-name='PROLONGED'/>
        <enum-item name='Briefly' original-name='BRIEF'/>
    </enum-type>

    <enum-type type-name='dance_form_partner_change_type' original-name='dance_group_dynamic_type' base-type='int32_t'> bay12: DanceGroupDynamicType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='LeadAdvanceAlongMainLineOfMotion' original-name='PARTNER_CHANGE_LEAD_FOLLOWS_LINE_OF_DANCE'/>
        <enum-item name='LeadAdvanceAgainstMainLineOfMotion' original-name='PARTNER_CHANGE_LEAD_AGAINST_LINE_OF_DANCE'/>
        <enum-item name='LeadTurningOutClockwise' original-name='PARTNER_CHANGE_LEAD_TURN_CW'/>
        <enum-item name='LeadTurningOutCounterClockwise' original-name='PARTNER_CHANGE_LEAD_TURN_CCW'/>
    </enum-type>

    <bitfield-type type-name="dance_move_flag" base-type="uint32_t"> bay12: DANCE_MOVE_FLAG_*
        <flag-bit name='BasicMovement' original-name='BASIC_MOVEMENT'/>
        <flag-bit name='DancePosition' original-name='POSITION'/>
        <flag-bit name='DanceMove' original-name='MOVE'/>
    </bitfield-type>

    <struct-type type-name='dance_form_move' original-name='dance_movest'>
        <stl-string name='name'/>
        <stl-vector type-name='dance_form_move_type' name='type' original-name='component'/>
        <stl-vector type-name='dance_form_move_modifier' name='modifier' original-name='component_adjective'/>
        <stl-vector type-name='int32_t' name='parameter' original-name='component_number' init-value='1' comment="Depends on type (turns are in signed angles, steps are in number of steps, etc.)"/>
        <stl-vector name='location' original-name='component_flag'>
            <bitfield base-type='uint32_t' type-name='dance_form_move_location'/>
        </stl-vector>
        <bitfield type-name='dance_move_flag' name='flag'/>
    </struct-type>

    <struct-type type-name='dance_form_section' original-name='dance_sectionst'>
        <enum type-name='dance_form_group_size' name='section_grouping'/>
        <int32_t name='section_grouping_number_min' init-value='1'/>
        <int32_t name='section_grouping_number_max' init-value='1'/>
        <enum type-name='dance_form_configuration' name='section_group_shape'/>
        <enum type-name='dance_form_movement_path' name='movement_path' original-name='section_line_of_dance'/>
        <int32_t name='move_id' original-name='section_basic_movement_index' comment="index in the moves vector"/>
        <enum type-name='dance_form_partner_distance' name='partner_distance' original-name='section_connection_distance'/>
        <enum type-name='dance_form_partner_intent' name='partner_intent' original-name='section_connection_tension'/>
        <enum type-name='dance_form_partner_cue_frequency' name='partner_cue_frequency' original-name='section_connection_time'/>
        <stl-vector type-name='dance_form_partner_change_type' name='partner_changes' original-name='section_group_dynamic'/>
        <bitfield base-type='uint32_t' type-name='dance_flag' name='dance_flag' original-name='section_dance_flag'/>
        <int32_t name='acts_out_event' original-name='section_acts_out_heid' ref-target='history_event'/>
        <int32_t name='acts_out_hf_story' original-name='section_acts_out_story_of_hfid' ref-target='historical_figure'/>
        <int32_t name='imitate_animal_movement' original-name='section_imitate_animal_movement' ref-target='creature_raw'/>
        <stl-vector type-name='dance_form_move_type' name='type' original-name='section_component'/>
        <stl-vector type-name='dance_form_move_modifier' name='modifier' original-name='section_component_adjective'/>
        <stl-vector type-name='int32_t' name='parameter' original-name='section_component_number' init-value='1' comment="Depends on type (turns are in signed angles, steps are in number of steps, etc.)"/>
        <stl-vector name='location' original-name='section_component_flag'>
            <bitfield type-name='dance_form_move_location'/>
        </stl-vector>
        <int32_t name='musical_passage_id' original-name='associated_musical_passage_id'/>
    </struct-type>

    <enum-type type-name='dance_form_context' original-name='dance_purpose_type' base-type='int32_t'> bay12: DancePurposeType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Sacred' original-name='SACRED'/>
        <enum-item name='Celebration' original-name='CELEBRATION'/>
        <enum-item name='Participation' original-name='PARTICIPATION'/>
        <enum-item name='Social' original-name='SOCIAL'/>
        <enum-item name='Performance' original-name='PERFORMANCE'/>
        <enum-item name='War' original-name='WAR'/>
    </enum-type>

    <bitfield-type type-name='dance_form_flag' base-type='uint32_t'> bay12: DANCE_FORM_FLAG_*
        <flag-bit comment='has_compositions' original-name='HAS_COMPOSITIONS'/>
    </bitfield-type>

    <struct-type type-name='dance_form' original-name='dance_formst' instance-vector='$global.world.dance_forms.all' key-field='id'>
        <int32_t name='id' original-name='global_id'/>

        <compound type-name='language_name' name='name'/>

        <int32_t name='musical_form_id' original-name='associated_musical_form_id'/>
        <int32_t name='music_written_content_id' original-name='associated_musical_composition_wcid' ref-target='written_content' comment='at most one of this and musical_form_id is non null'/>
        <enum type-name='dance_form_context' name='context' original-name='purpose'/>
        <int32_t name="originating_entity" original-name='origin_entity_id' ref-target="historical_entity" comment="ID of the entity from which the dance form originated."/>
        <int32_t name="original_author" original-name='origin_hfid' ref-target="historical_figure" comment="ID of the historical figure who developed the dance form."/>

        <bitfield base-type='uint32_t' type-name='dance_form_flag' name='flags' original-name='flag'/>

        <enum type-name='dance_form_group_size' name='group_size' original-name='dance_grouping'/>
        <int32_t name='group_number_min' original-name='dance_grouping_number_min' init-value='-1'/>
        <int32_t name='group_number_max' original-name='dance_grouping_number_max' init-value='-1'/>
        <enum type-name='dance_form_configuration' name='configuration' original-name='dance_group_shape'/>
        <enum type-name='dance_form_movement_path' name='movement_path' original-name='dance_line_of_dance'/>
        <int32_t name='basic_movement_index' original-name='dance_basic_movement_index' init-value='-1'/>
        <enum type-name='dance_form_partner_distance' name='partner_distance' original-name='dance_connection_distance' comment="NONE when not pair dance"/>
        <enum type-name='dance_form_partner_intent' name='partner_intent' original-name='dance_connection_tension' comment="NONE when not pair dance"/>
        <enum type-name='dance_form_partner_cue_frequency' name='partner_cue_frequency' original-name='dance_connection_time' comment="NONE when not pair dance and when 'normal'"/>
        <stl-vector type-name='dance_form_partner_change_type' name='partner_changes' original-name='dance_group_dynamic'/>
        <bitfield base-type='uint32_t' type-name='dance_flag' name='dance_flags' original-name='dance_flag'/>
        <int32_t name='event' original-name='dance_acts_out_heid' ref-target='history_event' comment='Event the dance acts out'/>
        <int32_t name='hfid' original-name='dance_acts_out_story_of_hfid' ref-target='historical_figure' comment="Character whose story the dance acts out"/>
        <int32_t name='race' original-name='dance_imitate_animal_movement' ref-target='creature_raw' comment="Creature whose movements are imitated"/>
        <stl-vector type-name='dance_form_move_type' name='move_type' original-name='dance_component'/>
        <stl-vector type-name='dance_form_move_modifier' name='move_modifier' original-name='dance_component_adjective'/>
        <stl-vector type-name='int32_t' name='move_parameter' original-name='dance_component_number' init-value='1' comment="Depends on type (turns are in signed angles, steps are in number of steps, etc.)"/>
        <stl-vector name='move_location' original-name='dance_component_flag'>
            <bitfield type-name='dance_form_move_location'/>
        </stl-vector>

        <stl-vector pointer-type='dance_form_section' name='sections' original-name='section'/>

        <stl-vector pointer-type='dance_form_move' name='moves' original-name='move'/>
    </struct-type>

    <struct-type type-name='dance_form_handlerst'>
        <stl-vector pointer-type='dance_form' name='all' original-name='global'/>
        <stl-vector pointer-type='dance_form' name='order_load' has-bad-pointers='true'/>
    </struct-type>
</data-definition>

