<data-definition>
    <bitfield-type type-name='beat_flag' original-name='rhythm_beat_flag' base-type='uint32_t'> bay12: RHYTHM_BEAT_FLAG_*
        <flag-bit name='Accent' original-name='ACCENT'/>
        <flag-bit name='Regular' original-name='REGULAR'/>
        <flag-bit name='Early' original-name='EARLY'/>
        <flag-bit name='Late' original-name='LATE'/>
    </bitfield-type>

    <struct-type type-name='rhythm_barst'>
        <pointer type-name='beat_flag' name='beat' original-name='beat_flag' is-array='true' comment="Length as per length field"/>
        <int32_t name='length' original-name='beat_num'/>
    </struct-type>

    <struct-type type-name='rhythm_pattern' original-name='rhythm_patternst'>
        <stl-string name='name'/>
        <stl-vector pointer-type='rhythm_barst' name='bars' original-name='bar'/>
        <pointer type-name='stl-string' name='beat_name' is-array='true' comment="length as per length field"/>
        <pointer type-name='stl-string' name='beat_abbreviation' is-array='true' comment="length as per length field"/>
        <int32_t name='length' original-name='beat_name_num'/>
    </struct-type>

    <bitfield-type type-name='rhythm_construction_pattern_flag' base-type='uint32_t'> bay12: RHYTHM_CONSTRUCTION_PATTERN_FLAG_*
        <flag-bit name='Primary' original-name='PRIMARY'/>
        <flag-bit name='Secondary' original-name='SECONDARY'/>
    </bitfield-type>

    <bitfield-type type-name='rhythm_construction_flag' base-type='uint32_t'> bay12: RHYTHM_CONSTRUCTION_FLAG_*
        <flag-bit name='polymetric' original-name='POLYMETRIC'/>
    </bitfield-type>

    <struct-type type-name='sub_rhythm' original-name='rhythm_constructionst'>
        <stl-string name='name'/>
        <stl-vector type-name='int32_t' name='patterns' original-name='rhythm_construction_pattern_index' comment="indices into patterns"/>
        <stl-vector type-name='rhythm_construction_pattern_flag' name='pattern_flags' original-name='rhythm_construction_pattern_flag' comment="Same length as patterns"/>
        <bitfield base-type='uint32_t' type-name='rhythm_construction_flag' name='flags' original-name='flag'/>
    </struct-type>

    <bitfield-type type-name='rhythm_flag' base-type='uint32_t'> bay12: RHYTHM_FLAG_*
        <flag-bit name='fundamental_polyrhythm' original-name='FUNDAMENTAL_POLYRHYTHM'/>
        <flag-bit name='fundamental_polymeter' original-name='FUNDAMENTAL_POLYMETER'/>
    </bitfield-type>

    <struct-type type-name='rhythm' original-name='rhythmst' instance-vector='$global.world.rhythms.all' key-field='id'>
        <int32_t name='id' original-name='global_id'/>

        <stl-vector pointer-type='rhythm_pattern' name='patterns' original-name='pattern'/>
        <stl-vector pointer-type='sub_rhythm' name='sub_rhythms' original-name='construction'/>
        <bitfield base-type='uint32_t' type-name='rhythm_flag' name='flags' original-name='flag'/>
    </struct-type>

    <struct-type type-name='rhythm_handlerst'>
        <stl-vector pointer-type='rhythm' name='all' original-name='global'/>

        <stl-vector pointer-type='rhythm' name='order_load' has-bad-pointers='true'/>
    </struct-type>
</data-definition>

