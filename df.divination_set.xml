    <enum-type type-name='divination_outcome_type' base-type='int32_t'> bay12: DivinationOutcomeType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='MediumBlessing' original-name='MEDIUM_BLESSING_INTERACTION_ON_DIVINER'/>
        <enum-item name='MinorBlessing' original-name='MINOR_BLESSING_INTERACTION_ON_DIVINER'/>
        <enum-item name='MediumCurse' original-name='MEDIUM_CURSE_INTERACTION_ON_DIVINER'/>
        <enum-item name='MinorCurse' original-name='MINOR_CURSE_INTERACTION_ON_DIVINER'/>
        <enum-item name='Fortune' original-name='TELL_FORTUNE'/>
    </enum-type>

    <struct-type type-name='divination_set_roll' original-name='divination_outcomest'>
        <stl-vector name='result' original-name='image_set_number' type-name='int32_t' ref-target='image_set' comment="When the divination die linked to the parent divination_set is rolled, the effect of this particular divination_set_roll will be carried out if the die lands on any of the values specified here."/>

        <enum name='effect_type' original-name='type' type-name='divination_outcome_type'/>
        <int32_t name='effect' original-name='outcome_id' comment="When effect_type is MediumBlessing, MinorBlessing, MediumCurse or MinorCurse, this is the ID of the interaction to be carried out (targeting the creature who rolled the divination die). When effect_type is Fortune, this determines which of the hardcoded divination fortune messages is to be displayed."/>
    </struct-type>

    <struct-type type-name='divination_set' original-name='divination_setst' instance-vector='$global.world.divination_sets.all' key-field='id'>
        <int32_t name='id' original-name='global_id' comment="currently matches index into vector"/>
        <int32_t name='deity_id' original-name='source_hfid' ref-target='historical_figure'/>
        <int32_t name='owner_id' original-name='source_enid' ref-target='historical_entity' comment="religion owning the set"/>
        <stl-vector name='image_set_ids' original-name='image_set_id' type-name='int32_t' ref-target='image_set'/>
        <stl-vector name='rolls' original-name='outcome' pointer-type='divination_set_roll'/>
    </struct-type>

    <struct-type type-name='divination_set_handlerst'>
        <stl-vector name='all' original-name='global' pointer-type='divination_set'/>
        <stl-vector name='order_load' pointer-type='divination_set' has-bad-pointers='true'/>
    </struct-type>
