<data-definition>
    <struct-type type-name='alert_statest'>
        <int32_t name='id' original-name='local_id'/>
        <stl-string name='name' original-name='nickname'/>
        <stl-vector name='burrows' original-name='civilian_burrow_id' type-name='int32_t' ref-target='burrow'/>
    </struct-type>

    <struct-type type-name='military_routinest'>
        <int32_t name='id' original-name='local_id'/>
        <stl-string name='name' original-name='nickname'/>
    </struct-type>

    <struct-type type-name='alert_state_infost'>
        <stl-vector name='list' original-name='alert_state' pointer-type='alert_statest'/>
        <int32_t name='next_id' original-name='next_alert_state_id'/>

        <stl-vector name="routines" original-name='military_routine' pointer-type='military_routinest'/> 0.50.01
        <int32_t name='next_routine_id' original-name='next_military_routine_id'/>

        <int32_t name='civ_alert_idx' original-name='current_general_alert_index' refers-to='$$._parent.list[$]'/>
    </struct-type>
</data-definition>

