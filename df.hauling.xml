<data-definition>
    <bitfield-type type-name='stop_stockpile_link_flag' base-type='uint32_t'> bay12: STOP_STOCKPILE_LINK_FLAG_*
        <flag-bit name='take' original-name='TAKE_FROM_PILE'/>
        <flag-bit name='give' original-name='GIVE_TO_PILE'/>
    </bitfield-type>

    <struct-type type-name='route_stockpile_link' original-name='stop_stockpile_linkst'>
        <int32_t name='building_id' original-name='bld_id' ref-target='building'/>
        <bitfield name='mode' original-name='flag' base-type='uint32_t' type-name='stop_stockpile_link_flag'/>
    </struct-type>

    <bitfield-type type-name='stop_leave_condition_flag' base-type='uint32_t'> bay12: STOP_LEAVE_CONDITION_FLAG_*
        <flag-bit name='at_most' original-name='USE_LESS'/>
        <flag-bit name='desired' original-name='DESIRED_ITEMS'/>
    </bitfield-type>

    <struct-type type-name='stop_depart_condition' original-name='stop_leave_conditionst'>
        <int32_t name='timeout' original-name='timer_trigger'/>
        <enum base-type='int32_t' name='direction' original-name='leave_dir'>
            <enum-item name='North'/>
            <enum-item name='South'/>
            <enum-item name='East'/>
            <enum-item name='West'/>
        </enum>
        <enum base-type='int32_t' name='mode' original-name='leave_mode'>
            <enum-item name='Push'/>
            <enum-item name='Ride'/>
            <enum-item name='Guide'/>
        </enum>
        <int32_t name='load_percent' original-name='full_percentage'
                 comment='broken display unless 0, 50 or 100'/>
        <bitfield name='flags' original-name='flag' base-type='uint32_t' type-name='stop_leave_condition_flag'/>
        <compound name='guide_path' original-name='potential_guide_path' type-name='coord_path'
                  comment='initialized on first run, and saved'/>
    </struct-type>

    <struct-type type-name='hauling_stop' original-name='hauling_stopst' key-field='id'>
        <int32_t name='id' original-name='local_id'/>
        <stl-string name='name' original-name='nickname'/>
        <compound name='pos' type-name='coord'/>

        <compound name='settings' original-name='stockpile' type-name='stockpile_settings'/>

        <stl-vector name='conditions' original-name='leave_condition' pointer-type='stop_depart_condition'/>
        <stl-vector name='stockpiles' original-name='stockpile_link' pointer-type='route_stockpile_link'/>

        <int32_t name='time_waiting' original-name='current_timer'/>
        <int32_t name='cart_id' original-name='currently_parked_itid' ref-target='item'/>
    </struct-type>

    <struct-type type-name='hauling_route' original-name='hauling_routest'
                 instance-vector='$global.plotinfo.hauling.routes' key-field='id'>
        <int32_t name='id' original-name='local_id'/>
        <stl-string name="name" original-name='nickname'/>
        <stl-vector name="stops" original-name='stop' pointer-type='hauling_stop'/>
        <stl-vector name="vehicle_ids" original-name='vehicle_id' type-name='int32_t' ref-target='vehicle'/>
        <stl-vector name="vehicle_stops" original-name='vehicle_current_stop'>
            <int32_t refers-to='$$._global.stops[$]'/>
        </stl-vector>
    </struct-type>

    <bitfield-type type-name='mode_hauling_stop_flag' base-type='uint32_t'> bay12: MODE_HAULING_STOP_FLAG_*
        <flag-bit name='DISCONNECTED_TRACK'/>
    </bitfield-type>

    <struct-type type-name='hauling_infost'>
        <stl-vector name='routes' original-name='route' pointer-type='hauling_route'/>
        <int32_t name='next_id' original-name='next_route_id'/>

        <int32_t name='scroll_position' original-name='scroll_position_route'/>
        <bool name='scrolling' original-name='scrolling_route'/>

        <stl-vector name='view_routes' original-name='i_route' pointer-type='hauling_route'/>
        <stl-vector name='view_stops' original-name='i_stop' pointer-type='hauling_stop'/>
        <stl-vector name='view_bad' original-name='i_stop_flag' type-name='mode_hauling_stop_flag'/>

        <bool name='in_stop' original-name='adding_stop'/>
        <int32_t name='adding_stop_route_id'/>

        <bool name='entering_nickname'/>
        <int32_t name='nickname_route_id'/>
        <int32_t name='nickname_stop_id'/>
    </struct-type>
</data-definition>

