<data-definition>
    -- Unused: influx_infost

    <bitfield-type type-name='report_site_flag' base-type='uint32_t'> bay12: REPORT_SITE_FLAG_*
        <flag-bit name='deep_special' original-name='HAVE_DEEP_STONE' comment='only when finding VEIN, not FEATURE'/>
    </bitfield-type>

    <struct-type type-name='entity_activity_statistics' original-name='reportst'>
        <compound name='food'> not a compound
            <int32_t name='total' original-name='ed'/>
            <int32_t name='meat' original-name='ed_meat'/>
            <int32_t name='fish' original-name='ed_fish'/>
            <int32_t name='other' original-name='ed_other'/>
            <int32_t name='seeds' original-name='ed_seeds'/>
            <int32_t name='plant' original-name='ed_plant'/>
            <int32_t name='drink' original-name='ed_drink'/>
        </compound>
        <static-array name='unit_counts' original-name='pop' type-name='int16_t' count='152' index-enum='profession'/> SAVEUNITNUM
        <int16_t name='population' original-name='popsum_totalciv'/>
        <int16_t name='menial_exempt' original-name='popsum_menial_exemption'/>
        <int16_t name='omnivores' original-name='popsum_eatall'/>
        <int16_t name='carnivores' original-name='popsum_carn'/>
        <int16_t name='trained_animals' original-name='popsum_trainedpet'/>
        <int16_t name='other_animals' original-name='popsum_untrainedpet'/>
        <int16_t name='potential_soldiers' original-name='soldiernum'/>
        <int32_t name='combat_aptitude' original-name='soldiervalue'/>

        <static-array name='item_counts' original-name='itemnum' type-name='int32_t' count='113' index-enum='item_type'/> SAVEITEMNUM
        <stl-vector name='created_weapons' original-name='weaponnum' type-name='int32_t' index-refers-to='$global.world.raws.itemdefs.weapons[$]'/>
        <compound name='wealth'> not a compound
            <int32_t name='total' original-name='wealth_sum'/>
            <int32_t name='weapons' original-name='wealth_weapon'/>
            <int32_t name='armor' original-name='wealth_worn'/>
            <int32_t name='furniture' original-name='wealth_furn'/>
            <int32_t name='other' original-name='wealth_other'/>
            <int32_t name='architecture' original-name='wealth_arch'/>
            <int32_t name='displayed' original-name='wealth_display'/>
            <int32_t name='held' original-name='wealth_showoff'/>
            <int32_t name='imported' original-name='wealth_offsite'/>
            <int32_t name='offered' original-name='wealth_offered'/>
            <int32_t name='exported' original-name='wealth_exported'/>
        </compound>
        <static-array name='recent_jobs' original-name='jobcompleted' count='7'> not an array - creature, all, glass, stone, metal, tree, shrub
            <static-array type-name='int32_t' index-enum='job_type'/>
        </static-array>

        <int32_t name='excavated_tiles' original-name='floorspace' comment='unhidden, subterranean, and excluding map features'/>

        <static-array count='5' type-name='int32_t' name='death_history' original-name='deathnumber'/>
        <static-array count='5' type-name='int32_t' name='insanity_history' original-name='crazynumber'/>
        <static-array count='5' type-name='int32_t' name='execution_history' original-name='executenumber'/>
        <static-array count='5' type-name='int32_t' name='noble_death_history' original-name='noble_death_ranksum'/>
        <int32_t name='total_deaths' original-name='totaldeathnumber'/>
        <int32_t name='total_insanities' original-name='totalcrazynumber'/>
        <int32_t name='total_executions' original-name='totalexecutenumber'/>

        <static-array count='4' type-name='int32_t' name='happiness_number'/>

        <int32_t name='num_artifacts' original-name='artifactnumber'/>

        <int32_t name='invaders_repelled' original-name='invadersrepelled'/>

        <compound name='knowledge' type-name='knowledgest'/>

        <int16_t name='discovered_water_features' original-name='water_feature_count'/>
        <int16_t name='discovered_subterranean_features' original-name='cave_feature_count'/>
        <int16_t name='discovered_chasm_features' original-name='open_cave_feature_count'/>
        <int16_t name='discovered_magma_features' original-name='magma_feature_count'/>
        <int16_t name='discovered_underworld_features' original-name='underworld_feature_count'/>

        <int32_t name='migrant_wave_idx' original-name='age_in_years'/>
        <stl-vector name='found_minerals' original-name='stone_mg_located' type-name='int32_t' ref-target='inorganic_raw'
                    comment="Added after 'you have struck' announcement"/>
        <bitfield name='found_misc' original-name='site_flag' base-type='uint32_t' type-name='report_site_flag'/>
    </struct-type>
</data-definition>

