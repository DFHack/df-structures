<data-definition>
    <struct-type type-name='adventure_log_map_displayst'>
        <int8_t name='map'/>
        <int8_t name="midmap"/>
        <int8_t name="localmap"/>
        <int8_t name='hide_map'/>
        <compound type-name='coord2d' name='cur_loc'/>
        <compound type-name='coord2d' name='cur_mm_loc'/>
        <compound type-name='coord2d' name='min'/>
        <compound type-name='coord2d' name='max'/>
        <compound type-name='coord2d' name='cursor'/>
        <int16_t name="midmap_highlight_sx"/>
        <int16_t name="midmap_highlight_ex"/>
        <int16_t name="midmap_highlight_sy"/>
        <int16_t name="midmap_highlight_ey"/>
    </struct-type>

    <struct-type type-name='bestiary_entryst'>
        <int32_t name='alpha_index'/>
        <pointer type-name='creature_knowledgest' name='ck'/>
        <stl-string name='list_name'/>

        <stl-string name='p_list_name'/>
        <compound type-name='curses_text_boxst' name='main_text_box'/>
    </struct-type>

    <struct-type type-name='agreement_entryst'>
        <pointer type-name='agreement' name='ag'/>

        <pointer type-name='squad' name='sq'/>
        <pointer type-name='squad_order' name='so'/>
        <bool name='squad_order_repeatable'/>

        <stl-string name='list_name'/>
        <stl-string name='simple_list_name'/>

        <stl-string name='p_list_name'/>
        <compound type-name='curses_text_boxst' name='main_text_box'/>

        <bool name='showing_commander'/>
        <int32_t name='ax'/>
        <int32_t name='ay'/>
    </struct-type>

    <struct-type type-name='histfig_entryst'>
        <pointer type-name='historical_figure' name='hf'/>
        <stl-string name='list_name'/>
        <stl-string name='simple_list_name'/>

        <stl-string name='p_list_name'/>
        <compound type-name='curses_text_boxst' name='main_text_box'/>

        <pointer type-name='identity' name='iden'/>
        <int32_t name='value'/>
    </struct-type>

    <struct-type type-name='site_entryst'>
        <pointer type-name='world_site' name='st'/>
        <stl-string name='list_name'/>
        <stl-string name='simple_list_name'/>

        <stl-string name='p_list_name'/>
        <compound type-name='curses_text_boxst' name='main_text_box'/>

        <int32_t name='value'/>
    </struct-type>

    <struct-type type-name='entity_entryst'>
        <pointer type-name='historical_entity' name='ent'/>
        <stl-string name='list_name'/>
        <stl-string name='simple_list_name'/>

        <stl-string name='p_list_name'/>
        <compound type-name='curses_text_boxst' name='main_text_box'/>

        <int32_t name='value'/>
    </struct-type>

    <struct-type type-name='subregion_entryst'>
        <pointer type-name='world_region' name='sr'/>
        <stl-string name='list_name'/>
        <stl-string name='simple_list_name'/>

        <stl-string name='p_list_name'/>
        <compound type-name='curses_text_boxst' name='main_text_box'/>
    </struct-type>

    <enum-type type-name='adventure_log_event_type' base-type='int32_t'> bay12: AdventureLogEventType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='INCIDENT'/>
        <enum-item name='RUMOR'/>
    </enum-type>

    <struct-type type-name='adventure_log_eventst'>
        <enum type-name='adventure_log_event_type' name='type'/>
        <pointer type-name='entity_event' name='rumor'/>
        <pointer type-name='incident' name='incident'/>
        <pointer type-name='adventure_rumor_datast' name='ard'/>
        <int32_t name='year'/>
        <int32_t name='season_count'/>

        <stl-string name='list_name'/>
        <stl-string name='simple_list_name'/>

        <stl-string name='summary'/>
        <stl-vector pointer-type='stl-string' name='key_word'/>

        <stl-string name='p_list_name'/>
        <compound type-name='curses_text_boxst' name='p_list_box'/>
        <compound type-name='curses_text_boxst' name='main_text_box'/>

        <int32_t name='ax' init-value='-1'/>
        <int32_t name='ay' init-value='-1'/>
        <int32_t name='recenter_mode'/>
        <static-array name='has_recenter_mode' type-name='bool' count='3'/>
    </struct-type>

    <struct-type type-name='artifact_entryst'>
        <pointer type-name='artifact_record' name='art'/>
        <stl-string name='list_name'/>
        <stl-string name='simple_list_name'/>

        <stl-string name='p_list_name'/>
        <compound type-name='curses_text_boxst' name='main_text_box'/>

        <compound type-name='artifact_rumor_locationst' name='arl'/>

        <int32_t name='ax'/>
        <int32_t name='ay'/>
    </struct-type>

    <enum-type type-name='adventure_log_mode' base-type='int16_t'> bay12: AdventureLogModeType
        <enum-item name="NONE" value='-1'/>
        <enum-item name="EVENTS"/>
        <enum-item name="AGREEMENTS"/>
        <enum-item name="PEOPLE"/>
        <enum-item name="SITES"/>
        <enum-item name="ENTITIES"/>
        <enum-item name="SUBREGIONS"/>

        <enum-item name="BESTIARY"/>
        <enum-item name="ARTIFACTS"/>
        <enum-item name="INTRIGUE"/>
        <enum-item name="INTRIGUE_ACTORS"/>
        <enum-item name="INTRIGUE_ORGANIZATIONS"/>
        <enum-item name="INTRIGUE_PLOTS"/>
        <enum-item name="BLANK_10"/>
        <enum-item name="BLANK_11"/>
        <enum-item name="BLANK_12"/>
    </enum-type>

    <class-type type-name='viewscreen_adventure_logst' inherits-from='viewscreen'>
        <stl-vector pointer-type='actor_entryst' name='base_actor_entry'/>
        <stl-vector pointer-type='organization_entryst' name='base_organization_entry'/>
        <stl-vector pointer-type='plot_entryst' name='base_plot_entry'/>
        <compound type-name='evidence_repositoryst' name='evidence_repository'/>

        <compound type-name='adventure_log_map_displayst' name='map_display'/>

        <int32_t name="selected"/>
        <int8_t name="line_on"/>
        <enum type-name='adventure_log_mode' name='mode'/>
        <enum type-name='adventure_log_mode' name='submode'/>
        <enum type-name='adventure_log_mode' name='saved_submode_intrigue'/>
        <int32_t name='adventure_log_event_text_scroll'/>
        <int32_t name='histfig_text_scroll'/>
        <int32_t name='bestiary_text_scroll'/>
        <int32_t name='entity_text_scroll'/>
        <int32_t name='site_text_scroll'/>
        <int32_t name='subregion_text_scroll'/>
        <int32_t name='artifact_text_scroll'/>

        <bool name='expand_text'/>
        <pointer type-name='organization_entry_nodest' name='selected_oen'/>

        <stl-string name='filter_str'/>
        <bool name='entering_filter'/>

        <bool name='initialized_intrigue_mode'/>

        <int32_t name='scroll_position_events'/>
        <int32_t name='scroll_position_agreements'/>
        <int32_t name='scroll_position_people'/>
        <int32_t name='scroll_position_sites'/>
        <int32_t name='scroll_position_entities'/>
        <int32_t name='scroll_position_subregions'/>
        <int32_t name='scroll_position_bestiary'/>
        <int32_t name='scroll_position_artifacts'/>
        <int32_t name='scroll_position_intrigue_actors'/>
        <int32_t name='scroll_position_intrigue_organizations'/>
        <int32_t name='scroll_position_intrigue_plots'/>
        <bool name='scrolling'/>

        <stl-vector pointer-type='site_entryst' name='base_site_entry'/>
        <stl-vector pointer-type='entity_entryst' name='base_entity_entry'/>
        <stl-vector pointer-type='subregion_entryst' name='base_subregion_entry'/>
        <stl-vector pointer-type='world_underground_region' name='base_feature_layer'/>
        <stl-vector pointer-type='agreement_entryst' name='base_agreement_entry'/>
        <stl-vector pointer-type='bestiary_entryst' name='base_bestiary_entry'/>
        <stl-vector pointer-type='adventure_log_eventst' name='base_adventure_log_event'/>
        <stl-vector pointer-type='histfig_entryst' name='base_histfig_entry'/>
        <stl-vector pointer-type='artifact_entryst' name='base_artifact_entry'/>

        <bool name='priority_sort_site'/>
        <bool name='priority_sort_entity'/>
        <bool name='priority_sort_histfig'/>
        <int32_t name='event_sort_mode'/>
        <bool name='set_priority_site'/>
        <bool name='set_priority_entity'/>
        <bool name='set_priority_histfig'/>
        <bool name='set_priority_event'/>
        <stl-vector pointer-type='site_entryst' name='value_site_entry'/>
        <stl-vector pointer-type='entity_entryst' name='value_entity_entry'/>
        <stl-vector pointer-type='subregion_entryst' name='value_subregion_entry'/>
        <stl-vector pointer-type='world_underground_region' name='value_feature_layer'/>
        <stl-vector pointer-type='agreement_entryst' name='value_agreement_entry'/>
        <stl-vector pointer-type='bestiary_entryst' name='value_bestiary_entry'/>
        <stl-vector pointer-type='adventure_log_eventst' name='value_adventure_log_event'/>
        <stl-vector pointer-type='histfig_entryst' name='value_histfig_entry'/>
        <stl-vector pointer-type='artifact_entryst' name='value_artifact_entry'/>
        <stl-vector pointer-type='actor_entryst' name='value_actor_entry'/>
        <stl-vector pointer-type='organization_entryst' name='value_organization_entry'/>
        <stl-vector pointer-type='plot_entryst' name='value_plot_entry'/>

        <stl-vector pointer-type='site_entryst' name='site_entry'/>
        <stl-vector pointer-type='entity_entryst' name='entity_entry'/>
        <stl-vector pointer-type='subregion_entryst' name='subregion_entry'/>
        <stl-vector pointer-type='world_underground_region' name='feature_layer'/>
        <stl-vector pointer-type='agreement_entryst' name='agreement_entry'/>
        <stl-vector pointer-type='bestiary_entryst' name='bestiary_entry'/>
        <stl-vector pointer-type='adventure_log_eventst' name='adventure_log_event'/>
        <stl-vector pointer-type='histfig_entryst' name='histfig_entry'/>
        <stl-vector pointer-type='artifact_entryst' name='artifact_entry'/>
        <stl-vector pointer-type='actor_entryst' name='actor_entry'/>
        <stl-vector pointer-type='organization_entryst' name='organization_entry'/>
        <stl-vector pointer-type='plot_entryst' name='plot_entry'/>
    </class-type>
</data-definition>

