<data-definition>
    <bitfield-type type-name="musical_form_feature" original-name='musical_flag' base-type="uint32_t"> bay12: MUSICAL_FLAG_*
        <flag-bit name='GlideFromNoteToNote' original-name='SLIDES'/>
        <flag-bit name='UseGraceNotes' original-name='GRACE_NOTES'/>
        <flag-bit name='UseMordents' original-name='MORDENTS'/>
        <flag-bit name='MakeTrills' original-name='TRILLS'/>
        <flag-bit name='PlayRapidRuns' original-name='RAPID_RUNS'/>
        <flag-bit name='LocallyImprovise' original-name='MELISMA'/>
        <flag-bit name='SpreadSyllablesOverManyNotes' original-name='SYLLABIC'/>
        <flag-bit name='MatchNotesAndSyllables' original-name='LOCAL_IMPROVISATION'/>

        <flag-bit name='Syncopate' original-name='EXTRA_SYNCOPATION'/>
        <flag-bit name='AddFills' original-name='FILLS'/>
        <flag-bit name='AlternateTensionAndRepose' original-name='TENSION_REPOSE'/>
        <flag-bit name='ModulateFrequently' original-name='LOCAL_MODULATION'/>
        <flag-bit name='PlayArpeggios' original-name='ARPEGGIOS'/>
        <flag-bit name='PlayStaccato' original-name='STACCATO'/>
        <flag-bit name='PlayLegato' original-name='LEGATO'/>
        <flag-bit name='FreelyAdjustBeats' original-name='FREELY_ADJUSTING_BEATS'/>
    </bitfield-type>

    <enum-type type-name='musical_form_style' original-name='musical_dynamic_type' base-type='int32_t'> bay12: MusicalDynamicType
        <enum-item name='None' original-name='NONE' value='-1'/>

        -- tempo styles
        <enum-item name='FreeTempo' original-name='TEMPO_AT_DISCRETION'/>
        <enum-item name='VerySlow' original-name='TEMPO_VERY_SLOW'/>
        <enum-item name='Slow' original-name='TEMPO_SLOW'/>
        <enum-item name='WalkingPace' original-name='TEMPO_WALKING_PACE'/>
        <enum-item name='ModeratelyPaced' original-name='TEMPO_MODERATE'/>
        <enum-item name='ModeratelyFast' original-name='TEMPO_MODERATELY_FAST'/>
        <enum-item name='Fast' original-name='TEMPO_FAST'/>
        <enum-item name='VeryFast' original-name='TEMPO_VERY_FAST'/>
        <enum-item name='ExtremelyFast' original-name='TEMPO_EXTREMELY_FAST'/>
        <enum-item name='DoubleTempo' original-name='TEMPO_DOUBLE_LAST_PASSAGE' />
        --  10
        <enum-item name='HalfTempo' original-name='TEMPO_HALF_LAST_PASSAGE'/>
        <enum-item name='Faster' original-name='TEMPO_MORE_QUICKLY_THAN_LAST_PASSAGE'/>
        <enum-item name='Slower' original-name='TEMPO_SLOWER_THAN_LAST_PASSAGE'/>
        <enum-item name='ResumeTempo' original-name='TEMPO_RESUME_PREVIOUS'/>
        <enum-item name='OriginalTempo' original-name='TEMPO_RESUME_ORIGINAL'/>
        <enum-item name='Accelerates' original-name='TEMPO_ACCELERATING'/>
        <enum-item name='SlowsAndBroadens' original-name='TEMPO_SLOWING_AND_BROADENING'/>
        <enum-item name='ConsistentlySlowing' original-name='TEMPO_CONSISTENTLY_SLOWING'/>
        <enum-item name='HurriedPace' original-name='TEMPO_HURRYING'/>
        <enum-item name='GraduallySlowsAtEnd' original-name='TEMPO_GRADUALLY_SLOWING'/>
        --  20
        -- loudness styles
        <enum-item name='WhisperedUndertones' original-name='LOUDNESS_WHISPERED_UNDERTONE'/>
        <enum-item name='VerySoft' original-name='LOUDNESS_VERY_SOFT'/>
        <enum-item name='Soft' original-name='LOUDNESS_SOFT'/>
        <enum-item name='ModeratelySoft' original-name='LOUDNESS_MODERATELY_SOFT'/>
        <enum-item name='ModeratelyLoud' original-name='LOUDNESS_MODERATELY_LOUD'/>
        <enum-item name='Loud' original-name='LOUDNESS_LOUD'/>
        <enum-item name='VeryLoud' original-name='LOUDNESS_VERY_LOUD'/>
        <enum-item name='BecomeLouderAndLouder' original-name='LOUDNESS_GROWING_LOUDER'/>
        <enum-item name='BecomeSofterAndSofter' original-name='LOUDNESS_GROWING_SOFTER'/>
        <enum-item name='FadeIntoSilence' original-name='LOUDNESS_FADING_TO_SILENCE'/>
        --  30
        <enum-item name='StartLoudThenImmediatelySoft' original-name='LOUDNESS_LOUD_THEN_IMMEDIATELY_SOFT'/>
        -- compound styles
        <enum-item name='SlowsAndDiesAwayAtEnd' original-name='COMPOUND_SLOWING_DOWN_AND_DYING_AWAY'/>
        <enum-item name='BecomesCalmerAtEnd' original-name='COMPOUND_BECOMING_CALMER'/>
        <enum-item name='BecomesFrenzied' original-name='COMPOUND_BECOMING_FRENZIED'/>
        -- mood styles
        <enum-item name='StressRhythm' original-name='MOOD_PRONOUNCED_STRESS'/>
        <enum-item name='BeStately' original-name='MOOD_STATELY'/>
        <enum-item name='BeBright' original-name='MOOD_BRIGHT'/>
        <enum-item name='BeLively' original-name='MOOD_LIVELY'/>
        <enum-item name='BeSkilled' original-name='MOOD_WITH_SKILL'/>
        <enum-item name='BeVigorous' original-name='MOOD_WITH_VIGOR'/>
        --  40
        <enum-item name='BeSpirited' original-name='MOOD_WITH_SPIRIT'/>
        <enum-item name='BeDelicate' original-name='MOOD_DELICATELY'/>
        <enum-item name='BeFiery' original-name='MOOD_WITH_FIRE'/>
        <enum-item name='BringSenseOfMotion' original-name='MOOD_WITH_MOTION'/>
        <enum-item name='BeDecisive' original-name='MOOD_DECISIVELY'/>
        <enum-item name='WithFeeling' original-name='MOOD_WITH_FEELING' since='v0.47.01'/>
        <enum-item name='FeelAgitated' original-name='MOOD_AGITATED'/>
        <enum-item name='BePassionate' original-name='MOOD_PASSIONATELY'/>
        <enum-item name='Sparkle' original-name='MOOD_SPARKLING'/>
        <enum-item name='BeBroad' original-name='MOOD_BROADLY'/>
        <enum-item name='BeMadeSweetly' original-name='MOOD_SWEETLY'/>
        --  50
        <enum-item name='BeStrong' original-name='MOOD_STRONG'/>
        <enum-item name='BeEnergetic' original-name='MOOD_ENERGETIC'/>
        <enum-item name='BeForceful' original-name='MOOD_FORCEFUL'/>
        <enum-item name='FeelHeroic' original-name='MOOD_HEROICALLY'/>
        <enum-item name='BeMadeExpressively' original-name='MOOD_EXPRESSIVELY'/>
        <enum-item name='FeelFurious' original-name='MOOD_FURIOUSLY'/>
        <enum-item name='BeJoyful' original-name='MOOD_JOYFULLY'/>
        <enum-item name='BeGrand' original-name='MOOD_GRANDLY'/>
        <enum-item name='BeMerry' original-name='MOOD_MERRILY'/>
        <enum-item name='BeGraceful' original-name='MOOD_GRACEFULLY'/>
        --  60
        <enum-item name='BuildAsItProceeds' original-name='MOOD_BUILDING'/>
        <enum-item name='EvokeTears' original-name='MOOD_TEARFULLY'/>
        <enum-item name='BeMelancholic' original-name='MOOD_MELANCHOLIC'/>
        <enum-item name='FeelMournful' original-name='MOOD_MOURNFUL'/>
        <enum-item name='BeMadeWithLightTouch' original-name='MOOD_WITH_A_LIGHT_TOUCH'/>
        <enum-item name='FeelHeavy' original-name='MOOD_HEAVILY'/>
        <enum-item name='FeelMysterious' original-name='MOOD_MYSTERIOUSLY'/>
        <enum-item name='BeJumpy' original-name='MOOD_JUMPY'/>
        <enum-item name='FeelPlayful' original-name='MOOD_PLAYFULLY'/>
        <enum-item name='FeelTender' original-name='MOOD_TENDERLY'/>
        --  70
        <enum-item name='FeelCalm' original-name='MOOD_CALMLY'/>
        <enum-item name='BeTriumphant' original-name='MOOD_TRIUMPHANTLY'/>
    </enum-type>

    <enum-type type-name='musical_form_pitch_style' original-name='harmonic_structure_type' base-type='int32_t'> bay12: HarmonicStructureType
        <enum-item name='None' original-name='NONE' value='-1'/>
        <enum-item name='SinglePitchesOnly' original-name='SINGLE_NOTES_ALWAYS'/>
        <enum-item name='IntervalsOnly' original-name='ONLY_INTERVALS'/>
        <enum-item name='SparseChords' original-name='SPARSE'/>
        <enum-item name='PitchClusters' original-name='DENSELY_PACKED'/>
        <enum-item name='ChordLayers' original-name='BROADLY_LAYERED'/>
    </enum-type>

    <bitfield-type type-name='melody_accidental_flag' base-type='uint32_t'> bay12: MELODY_ACCIDENTAL_FLAG_*
        <flag-bit name='rising' original-name='ON_RISE' comment='otherwise falling'/>
        <flag-bit name='flattened' original-name='FLATTENED'/>
        <flag-bit name='sharpened' original-name='SHARPENED'/>
    </bitfield-type>

    <struct-type type-name='musical_form_interval' original-name='melody_accidentalst'>
        <int32_t name='degree'/>
        <bitfield name='flags' original-name='flag' base-type='uint32_t' type-name='melody_accidental_flag'/>
    </struct-type>

    <enum-type type-name='musical_form_melody_style' original-name='melody_pattern_type' base-type='int32_t'> bay12: MelodyPatternType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Rising' original-name='RISING'/>
        <enum-item name='Falling' original-name='FALLING'/>
        <enum-item name='RisingFalling' original-name='RISING_FALLING'/>
        <enum-item name='FallingRising' original-name='FALLING_RISING'/>
    </enum-type>

    <enum-type type-name='musical_form_melody_frequency' original-name='melody_frequency_type' base-type='int32_t'> bay12: MelodyFrequencyType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Always' original-name='REQUIRED'/>
        <enum-item name='Often' original-name='COMMON'/>
        <enum-item name='Sometimes' original-name='OCCASIONAL'/>
    </enum-type>

    <struct-type type-name='musical_form_melodies' original-name='melodyst'>
        <enum name='style' original-name='pattern' type-name='musical_form_melody_style'/>
        <enum name='frequency' type-name='musical_form_melody_frequency'/>
        <stl-vector name='intervals' original-name='accidental' pointer-type='musical_form_interval'/>
        <bitfield name='features' original-name='melody_musical_flag' base-type='uint32_t' type-name='musical_form_feature'/>
    </struct-type>

    <enum-type type-name='musical_form_passage_length_type' original-name='voice_phrase_length_type' base-type='int32_t'> bay12: VoicePhraseLengthType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Short' original-name='SHORT' comment='2 bars'/>
        <enum-item name='MidLength' original-name='MIDDLE' comment='4 bars'/>
        <enum-item name='Long' original-name='LONG' comment='8 bars'/>
        <enum-item name='Varied' original-name='VARIED' comment='2-8 bars'/>
    </enum-type>

    <enum-type type-name='musical_form_passage_component_type' original-name='voice_role_type' base-type='int32_t'> bay12: VoiceRoleType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Melody' original-name='MELODY'/>
        <enum-item name='Counterpoint' original-name='MELODY_COUNTERPOINT'/>
        <enum-item name='Harmony' original-name='HARMONY'/>
        <enum-item name='Rhythm' original-name='RHYTHM'/>
        <enum-item name='Unspecified' original-name='SPOKEN'/>
    </enum-type>

    <enum-type type-name='musical_form_passage_type' original-name='musical_passage_type' base-type='int32_t'> bay12: MusicalPassageType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Unrelated' original-name='SIMPLE'/>
        <enum-item name='Introduction' original-name='INTRODUCTION'/>
        <enum-item name='Exposition' original-name='EXPOSITION'/>
        <enum-item name='Recapitulation' original-name='RECAPITULATION'/>
        <enum-item name='Synthesis' original-name='SYNTHESIS'/>
        <enum-item name='Verse' original-name='VERSE'/>
        <enum-item name='Chorus' original-name='CHORUS'/>
        <enum-item name='Finale' original-name='FINALE'/>
        <enum-item name='Coda' original-name='CODA'/>
        <enum-item name='BridgePassage' original-name='BRIDGE'/>
        <enum-item name='Theme' original-name='THEME'/>
        <enum-item name='Variation' original-name='VARIATIONS'/>
    </enum-type>

    <struct-type type-name='musical_form_passage' original-name='musical_form_passagest'>
        <enum name='type' type-name='musical_form_passage_type'/>
        <int32_t name='passage_reference' original-name='relevant_passage_index' init-value='-1' comment="used when doing Exposition, Recapitualation, Synthesis, and Variation"/>
        <int32_t name='passage_range_end' original-name='relevant_passage_index2' init-value='-1' comment="when doing Synthesis of a range of passages"/>
        <int32_t name='min_number'/>
        <int32_t name='max_number'/>
        <int32_t name='poetic_form_id' ref-target='poetic_form'/>
        <int32_t name='written_content_id' original-name='poem_wcid' ref-target='written_content' comment="suspect bug in exported legends (and possibly DF itself) as no mentioning of the poems (or any alternative) referenced here were mentioned in the two entries examined"/>
        <int32_t name='scale_id' ref-target='scale'/>
        <int32_t name='scale_sub_id' original-name='scale_construction_index' comment="references the scales element of the scale"/>
        <int32_t name='rhythm_id' ref-target='rhythm'/>
        <int32_t name='sub_rhythm' original-name='rhythm_construction_index' comment="Guess, based on the pattern above"/>
        <int32_t name='rhythm_pattern' original-name='rhythm_pattern_index' comment="references the patterns element of rhythm"/>
        <stl-vector name='instruments' original-name='voice_index' type-name='int32_t' comment="indices into the instruments vector"/>
        <stl-vector name='components' original-name='voice_role' type-name='musical_form_passage_component_type'/>
        <stl-vector name='passage_lengths' original-name='voice_phrase_length' type-name='musical_form_passage_length_type'/>
        <stl-vector name='lowest_register_range' original-name='voice_min_register' type-name='int32_t' init-value='-1' comment="0-3 seen. Probably indices into the registers of the instruments referenced. Found no field for timbre description, though"/>
        <stl-vector name='highest_register_range' original-name='voice_max_register' type-name='int32_t' init-value='-1' comment="0-3 seen. Probably indices into the registers of the instruments referenced. Found no field for timbre description, though"/>
        <enum name='tempo_style' original-name='passage_dynamic_1' type-name='musical_form_style'/>
        <enum name='dynamic_style' original-name='passage_dynamic_2' type-name='musical_form_style'/>
        <enum name='overall_style' original-name='passage_dynamic_3' type-name='musical_form_style'/>
        <bitfield name='features' original-name='passage_musical_flag' base-type='uint32_t' type-name='musical_form_feature'/>
        <enum name='pitch_style' original-name='passage_harmonic_structure' type-name='musical_form_pitch_style'/>
        <stl-vector name='melodies' original-name='passage_melody' pointer-type='musical_form_melodies'/>
        <int32_t name='min_unit_length' init-value='-1'/>
        <int32_t name='max_unit_length' init-value='-1'/>
    </struct-type>

    <bitfield-type type-name='musical_form_voice_flag' base-type='uint32_t'> bay12: MUSICAL_FORM_VOICE_FLAG_*
        <flag-bit name='singer' original-name='SINGING'/>
        <flag-bit name='speaker' original-name='SPOKEN'/>
        <flag-bit name='chanter' original-name='CHANTED'/>
    </bitfield-type>

    <struct-type type-name='musical_form_instruments' original-name='musical_form_voicest'>
        <int32_t name='instrument_subtype' original-name='instrument_id' ref-target='itemdef_instrumentst' comment='-1 = vocal'/>
        <bitfield base-type='uint32_t' type-name='musical_form_voice_flag' name='substitutions' original-name='flag'/>
        <bitfield base-type='uint32_t' type-name='musical_form_feature' name='features' original-name='voice_musical_flag'/>
        <int32_t name='minimum_required' original-name='min_number'/>
        <int32_t name='maximum_permitted' original-name='max_number'/>
        <enum name='dynamic_style' original-name='voice_dynamic_1' type-name='musical_form_style'/>
        <enum name='overall_style' original-name='voice_dynamic_2' type-name='musical_form_style'/>
    </struct-type>

    <struct-type type-name='musical_form_play_orderst'>
        <static-array name='passage_index' count='3' type-name='int32_t'/>
        <int32_t name='passage_num'/>
        <int32_t name='min_number'/>
        <int32_t name='max_number'/>
    </struct-type>

    <enum-type type-name='musical_form_purpose' original-name='musical_form_intent_type' base-type='int32_t'> bay12: MusicalFormIntentType
        <enum-item name='NONE' value='-1'/>
        <enum-item name='Entertainment' original-name='ENTERTAINMENT'/>
        <enum-item name='Commemoration' original-name='COMMEMORATION'/>
        <enum-item name='Devotion' original-name='DEVOTIONAL'/>
        <enum-item name='Military' original-name='MILITARY_MARCH'/>
    </enum-type>

    <bitfield-type type-name='musical_form_flag' base-type='uint32_t'>
        <flag-bit name='produces_individual_songs' original-name='HAS_COMPOSITIONS'/>
        <flag-bit name='repeats_as_necessary' original-name='REPEATS_AS_NECESSARY'/>
    </bitfield-type>

    <struct-type type-name='musical_form' original-name='musical_formst' instance-vector='$global.world.musical_forms.all' key-field='id'>
        <int32_t name='id' original-name='global_id'/>

        <compound name='name' type-name='language_name'/>
        <int32_t name="originating_entity" original-name='origin_entity_id' ref-target="historical_entity" comment="ID of the entity from which the musical form originated."/>
        <int32_t name="original_author" original-name='origin_hfid' ref-target="historical_figure" comment="historical figure ID of the composer"/>

        <stl-vector name='passages' original-name='passage' pointer-type='musical_form_passage'/>
        <stl-vector name='instruments' original-name='voice' pointer-type='musical_form_instruments'/>
        <stl-vector name='melodies' original-name='melody' pointer-type='musical_form_melodies'/>
        <stl-vector name='play_order' pointer-type='musical_form_play_orderst'/>

        <enum name='tempo_style' original-name='form_dynamic_1' type-name='musical_form_style'/>
        <enum name='dynamic_style' original-name='form_dynamic_2' type-name='musical_form_style'/>
        <enum name='overall_style' original-name='form_dynamic_3' type-name='musical_form_style'/>
        <int32_t name='poetic_form_id' ref-target='poetic_form'/>
        <int32_t name='written_content_id' original-name='poem_wcid' ref-target='written_content'/>

        <int32_t name='scale_id' ref-target='scale'/>
        <int32_t name='scale_subid' original-name='scale_construction_index' comment='reference to scale_sub2'/>
        <int32_t name='rhythm_id' ref-target='rhythm'/>
        <int32_t name='sub_rhythm' original-name='rhythm_construction_index' comment='reference to sub_rhythms'/>
        <int32_t name='rhythm_pattern' original-name='rhythm_pattern_index' comment='reference to patterns'/>

        <bitfield name='features' original-name='musical_flag' type-name='musical_form_feature'/>
        <enum name='pitch_style' original-name='harmonic_structure' type-name='musical_form_pitch_style'/>

        <enum name='purpose' original-name='intent' type-name='musical_form_purpose'/>
        <int32_t name='devotion_target' original-name='intent_id_index' ref-target='historical_figure'/>

        <bitfield base-type='uint32_t' type-name='musical_form_flag' name='flags' original-name='flag'/>
    </struct-type>

    <struct-type type-name='musical_form_handlerst'>
        <stl-vector name='all' original-name='global' pointer-type='musical_form'/>

        <stl-vector name='order_load' pointer-type='musical_form' has-bad-pointers='true'/>
    </struct-type>
</data-definition>

