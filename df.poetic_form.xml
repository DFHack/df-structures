        <flag-bit name="ReadOrthogonally" original-name='CAN_BE_READ_DIRECTIONALLY'/>
        <flag-bit name="Emerge" original-name='CAN_BE_READ_PATHWISE'/>
        <flag-bit name="Assonance" original-name='ASSONANCE'/>
        <flag-bit name="Consonance" original-name='CONSONANCE'/>
