        <enum-item name='Describe' original-name='DESCRIBE'/>
        <enum-item name='Satirize' original-name='SATIRE'/>
        <enum-item name='AmuseAudience' original-name='AMUSE'/>
        <enum-item name='Complain' original-name='COMPLAIN'/>
        <enum-item name='Renounce' original-name='RENUNCIATION'/>
        <enum-item name='MakeApology' original-name='APOLOGY'/>
        <enum-item name='ExpressPleasure' original-name='EXPRESS_PLEASURE'/>
        <enum-item name='ExpressGrief' original-name='GRIEVE'/>
        <enum-item name='Praise' original-name='PRAISE'/>
        <enum-item name='TeachMoralLesson' original-name='TEACH'/>
        <enum-item name='MakeAssertion' original-name='MAKE_ASSERTION'/>
        <enum-item name='MakeCounterAssertion' original-name='MAKE_COUNTER_ASSERTION'/>
