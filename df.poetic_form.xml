        <enum-item name='Beseech' original-name='BESEECH' since='v0.47.01'/>
    </enum-type>

    <bitfield-type type-name="poetic_form_feature" original-name='poetic_form_line_flag' base-type="uint32_t"> bay12: POETIC_FORM_LINE_FLAG_*
        <flag-bit name="InternalRhyme" original-name='INTERNAL_RHYMES'/>
        <flag-bit name="EndRhymesDontMatch" original-name='SOFT_END_RHYME'/>
        <flag-bit name="Alliteration" original-name='ALLITERATION'/>
