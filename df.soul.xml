<data-definition>
    -- Unused: PracticalExperienceType

    <struct-type type-name='unit_instrument_skill' original-name='practical_experience_instrumentst'>
        <int32_t name="id" original-name='instrument_id' ref-target='itemdef_instrumentst'/>
        <code-helper name='describe'>(describe-obj $global.world.raws.itemdefs.instruments[$.id].name)</code-helper>
        <enum base-type='int32_t' type-name='skill_rating' name="rating" original-name='level'/>
        <int32_t name="experience" original-name='ip'/>
    </struct-type>

    <struct-type type-name='unit_poetic_skill' original-name='practical_experience_poetic_formst'>
        <int32_t name="id" original-name='poetic_form_id' ref-target='poetic_form'/>
        <code-helper name='describe'>(describe-obj $global.world.poetic_forms.all[$.id].name)</code-helper>
        <enum base-type='int32_t' type-name='skill_rating' name="rating" original-name='level'/>
        <int32_t name="experience" original-name='ip'/>
    </struct-type>

    <struct-type type-name='unit_musical_skill' original-name='practical_experience_musical_formst'>
        <int32_t name="id" original-name='musical_form_id' ref-target='musical_form'/>
        <code-helper name='describe'>(describe-obj $global.world.musical_forms.all[$.id].name)</code-helper>
        <enum base-type='int32_t' type-name='skill_rating' name="rating" original-name='level'/>
        <int32_t name="experience" original-name='ip'/>
    </struct-type>

    <struct-type type-name='unit_dance_skill' original-name='practical_experience_dance_formst'>
        <int32_t name="id" original-name='dance_form_id' ref-target='dance_form'/>
        <code-helper name='describe'>(describe-obj $global.world.dance_forms.all[$.id].name)</code-helper>
        <enum base-type='int32_t' type-name='skill_rating' name="rating" original-name='level'/>
        <int32_t name="experience" original-name='ip'/>
    </struct-type>

    <struct-type type-name='practical_experiencest'>
        <stl-vector pointer-type='unit_instrument_skill' name='musical_instruments' original-name='instrument'/>
        <stl-vector pointer-type='unit_poetic_skill' name='poetic_forms' original-name='poetic_form'/>
        <stl-vector pointer-type='unit_musical_skill' name='musical_forms' original-name='musical_form'/>
        <stl-vector pointer-type='unit_dance_skill' name='dance_forms' original-name='dance_form'/>
    </struct-type>

    <struct-type type-name='unit_soul' original-name='soulst'>
        <int32_t name='id' original-name='global_id'/>

        <compound type-name='language_name' name='name'/>

        <int32_t name='race' original-name='orig_race' ref-target='creature_raw'/>
        <enum type-name='pronoun_type' name='sex' original-name='orig_gender'/>
        <int16_t name='caste' original-name='orig_caste' ref-target='caste_raw' aux-value='$$.race'/>

        <code-helper name='describe'>
            (describe-obj $.name)
            (awhen (find-creature $.race)
            (fmt "~:(~A ~A~)" $it.caste[$.caste].caste_id $it.creature_id))
        </code-helper>

        <bitfield type-name='orientation_flags' original-name='sexual_orientation_flag' name='orientation_flags'/>
        <int32_t name='birth_year' init-value='-1'/>
        <int32_t name='birth_time' original-name='birth_season_count' init-value='-1'/>
        <int32_t name='curse_year' original-name='frozen_age_year' init-value='-1' since='v0.34.01'/>
        <int32_t name='curse_time' original-name='frozen_age_season_count' init-value='-1' since='v0.34.01'/>
        <int32_t name='birth_year_bias' original-name='credit_age_year' init-value='0' since='v0.34.01'/>
        <int32_t name='birth_time_bias' original-name='credit_age_season_count' init-value='0' since='v0.34.01'/>
        <int32_t name='old_year' original-name='age_death_year' init-value='-1'/>
        <int32_t name='old_time' original-name='age_death_season_count' init-value='-1'/>

        <static-array type-name='unit_attribute' name='mental_attrs' original-name='mental_attribute' index-enum='mental_attribute_type'/>

        <stl-vector pointer-type='unit_skill' name='skills' original-name='skill'/>
        <stl-vector pointer-type='unit_preference' name='preferences' original-name='pref'/>

        <compound type-name='unit_personality' name='personality'/>

        <pointer type-name='practical_experiencest' name='performance_skills' original-name='practical_experience' since='v0.42.01'/>
    </struct-type>
</data-definition>

