<data-definition>
    <enum-type type-name='music_flag_type'> bay12: MusicFlagType
        <enum-item name='GENERATED'/>
    </enum-type>

    <struct-type type-name='musicst'>
        <stl-string name='token'/>
        <int32_t name='index'/>
        <stl-vector pointer-type='stl-string' name='current_definition'/>

        <df-flagarray name='flags' original-name='flag' index-enum='music_flag_type'/>

        <int32_t name='source_hfid' ref-target='historical_figure'/>
        <int32_t name='source_enid' ref-target='historical_entity'/>

        <int32_t name='song'/>
        <stl-vector type-name='int32_t' name='card'/>

        <stl-vector type-name='music_event_type' name='m_event'/>
        <stl-vector type-name='music_context_type' name='context'/>

        <int32_t name='frequency'/>
    </struct-type>

    -- Unused: music_handling_informationst

    <struct-type type-name='music_handlerst'>
        <stl-vector pointer-type='musicst' name='all' original-name='music'/>
    </struct-type>
</data-definition>

